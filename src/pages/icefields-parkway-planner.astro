---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const stops = [
  { km: 0, name: 'Lake Louise (Start)', time: 0, stopMin: 0, type: 'start', desc: 'Fill up on gas and grab coffee. Last reliable gas station until Saskatchewan Crossing (km 77).' },
  { km: 2, name: 'Herbert Lake', time: 2, stopMin: 15, type: 'viewpoint', desc: 'Perfect mirror reflections on calm mornings. Quick 2-minute walk from pullout. Best before 9 AM.' },
  { km: 9, name: 'Hector Lake Viewpoint', time: 8, stopMin: 10, type: 'viewpoint', desc: 'Turquoise lake framed by Mount Hector. Roadside pullout, no walking required.' },
  { km: 17, name: 'Bow Lake', time: 15, stopMin: 30, type: 'highlight', desc: 'One of the best stops on the Parkway. Walk to the shoreline (5 min) for views of Bow Glacier. Num-Ti-Jah Lodge serves food.' },
  { km: 22, name: 'Crowfoot Glacier Viewpoint', time: 18, stopMin: 10, type: 'viewpoint', desc: 'Named for its three-toed appearance (though the third toe has melted). Roadside viewpoint.' },
  { km: 40, name: 'Peyto Lake Viewpoint', time: 30, stopMin: 45, type: 'highlight', desc: 'The iconic fox-head-shaped turquoise lake. New viewing platform (2023). 15-min walk from parking. Go early — lot fills by 10 AM in summer.' },
  { km: 57, name: 'Mistaya Canyon', time: 42, stopMin: 30, type: 'trail', desc: 'Short but dramatic canyon carved through limestone. 10-min walk to the canyon bridge. One of the most underrated stops.' },
  { km: 77, name: 'Saskatchewan River Crossing', time: 55, stopMin: 20, type: 'services', desc: 'The ONLY services between Lake Louise and Jasper. Gas, food, washrooms. The food is mediocre but the gas is essential.' },
  { km: 103, name: 'Parker Ridge Trail', time: 75, stopMin: 120, type: 'trail', desc: 'Best short hike on the Parkway. 2.7 km to above-treeline views of Saskatchewan Glacier. Allow 2 hours. Do not skip this.' },
  { km: 107, name: 'Columbia Icefield Centre', time: 80, stopMin: 60, type: 'highlight', desc: 'Glacier Skywalk and Ice Explorer tours depart here. Pre-book tickets. Even without tours, the Athabasca Glacier viewpoint is free and incredible.' },
  { km: 117, name: 'Tangle Falls', time: 88, stopMin: 10, type: 'viewpoint', desc: 'Waterfall right beside the road. Pull over and walk 30 seconds. Often missed because people are tired by this point.' },
  { km: 135, name: 'Sunwapta Falls', time: 100, stopMin: 30, type: 'highlight', desc: 'Powerful waterfall in a narrow gorge. 5-min walk from parking. Upper and lower viewpoints. Worth the stop.' },
  { km: 170, name: 'Athabasca Falls', time: 120, stopMin: 30, type: 'highlight', desc: 'Thundering falls through a narrow canyon. Multiple viewpoints connected by bridges. Last major stop before Jasper.' },
  { km: 233, name: 'Jasper (End)', time: 160, stopMin: 0, type: 'end', desc: 'Welcome to Jasper. Total drive without stops: ~2.5-3 hours. With stops: 6-9 hours.' },
];

const stopsJSON = JSON.stringify(stops);
---

<BaseLayout title="Icefields Parkway Planner — Stop-by-Stop Driving Guide" description="Interactive Icefields Parkway planner. Every stop from Lake Louise to Jasper with driving times, suggested durations, and what not to miss. Plan your perfect road trip.">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How long does the Icefields Parkway take?', acceptedAnswer: { '@type': 'Answer', text: 'The Icefields Parkway (Highway 93 North) from Lake Louise to Jasper is 233 km and takes 2.5-3 hours of pure driving time. However, you should plan 6-9 hours total to stop at the key viewpoints and do at least one short hike (Parker Ridge is the must-do). If you want to hike Parker Ridge and visit the Columbia Icefield, plan for 8+ hours.' } },
      { '@type': 'Question', name: 'What are the must-stop spots on the Icefields Parkway?', acceptedAnswer: { '@type': 'Answer', text: 'The essential stops on the Icefields Parkway are: Bow Lake (km 17, turquoise lake), Peyto Lake Viewpoint (km 40, iconic turquoise lake from above), Mistaya Canyon (km 57, dramatic narrow canyon), Parker Ridge Trail (km 103, best short hike), Columbia Icefield Centre (km 107, glacier views), Sunwapta Falls (km 135, powerful gorge waterfall), and Athabasca Falls (km 170, thundering canyon falls). Saskatchewan River Crossing (km 77) is the only gas station between Lake Louise and Jasper.' } },
      { '@type': 'Question', name: 'Where do I get gas on the Icefields Parkway?', acceptedAnswer: { '@type': 'Answer', text: 'There is only ONE gas station on the entire 233 km Icefields Parkway: Saskatchewan River Crossing at km 77. Fill up in Lake Louise before you start. In Jasper at the end. The gas at Saskatchewan Crossing is expensive but essential if you are running low.' } },
    ],
  })} />

  <div class="container">
    <Breadcrumbs items={[{ label: 'Icefields Parkway Planner' }]} />
  </div>

  <section class="page-hero">
    <img src="https://images.unsplash.com/photo-1505578066749-4faedfc40c26?w=1600&q=80" alt="Icefields Parkway mountain road" class="page-hero-bg" loading="eager" fetchpriority="high" />
    <div class="page-hero-content">
      <span class="badge">Road Trip Planner</span>
      <h1>Icefields Parkway</h1>
      <p>233 km of the world's most scenic road. Plan every stop from Lake Louise to Jasper.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="planner-summary">
        <div class="summary-stat"><span class="summary-num">233</span><span>km total</span></div>
        <div class="summary-stat"><span class="summary-num">14</span><span>stops</span></div>
        <div class="summary-stat"><span class="summary-num" id="total-time">--</span><span>hours with stops</span></div>
        <div class="summary-stat"><span class="summary-num">1</span><span>gas station</span></div>
      </div>

      <p style="text-align:center;font-size:0.85rem;color:var(--color-text-light);margin:1rem 0 2rem;">Toggle stops on/off to build your custom itinerary. Total time updates automatically.</p>

      <div class="stops-timeline">
        {stops.map((stop, i) => (
          <div class={`stop-card stop-${stop.type}`} data-stop-idx={i} data-stop-min={stop.stopMin}>
            <div class="stop-km">km {stop.km}</div>
            <div class="stop-body">
              <div class="stop-top">
                <h3>{stop.name}</h3>
                {stop.stopMin > 0 && (
                  <label class="stop-toggle">
                    <input type="checkbox" checked data-idx={i} />
                    <span>{stop.stopMin} min</span>
                  </label>
                )}
              </div>
              <p>{stop.desc}</p>
              {stop.type === 'highlight' && <span class="stop-tag">Must-Stop</span>}
              {stop.type === 'trail' && <span class="stop-tag stop-tag-trail">Hike</span>}
              {stop.type === 'services' && <span class="stop-tag stop-tag-services">Gas & Food</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ stopsJSON }}>
  const stops = JSON.parse(stopsJSON);

  function updateTotal() {
    const driveMin = stops[stops.length - 1].time;
    let stopMin = 0;
    document.querySelectorAll('.stop-toggle input:checked').forEach(cb => {
      stopMin += stops[parseInt(cb.dataset.idx)].stopMin;
    });
    const totalHours = ((driveMin + stopMin) / 60).toFixed(1);
    document.getElementById('total-time').textContent = totalHours;
  }

  document.querySelectorAll('.stop-toggle input').forEach(cb => {
    cb.addEventListener('change', updateTotal);
  });

  updateTotal();
</script>

<style>
  .planner-summary { display: flex; justify-content: center; gap: 2.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .summary-stat { display: flex; flex-direction: column; align-items: center; }
  .summary-num { font-family: var(--font-heading); font-size: 2.5rem; font-weight: 700; color: var(--color-primary); line-height: 1; }
  .summary-stat span:last-child { font-size: 0.8rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.04em; }

  .stops-timeline { display: flex; flex-direction: column; gap: 0; position: relative; }
  .stops-timeline::before { content: ''; position: absolute; left: 40px; top: 0; bottom: 0; width: 3px; background: var(--color-bg-alt); }

  .stop-card { display: flex; gap: 1.25rem; padding: 1.25rem 0; position: relative; }
  .stop-km {
    min-width: 80px; font-size: 0.75rem; font-weight: 700; color: var(--color-text-light);
    text-align: right; padding-top: 0.3rem; position: relative; z-index: 1;
  }
  .stop-body { flex: 1; background: var(--color-white); border-radius: var(--radius); padding: 1.25rem; box-shadow: var(--shadow); }
  .stop-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; }
  .stop-top h3 { font-size: 1rem; }
  .stop-body p { font-size: 0.85rem; color: var(--color-text-light); line-height: 1.5; }

  .stop-toggle { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--color-text-light); cursor: pointer; }
  .stop-toggle input { accent-color: var(--color-primary); }

  .stop-tag { display: inline-block; margin-top: 0.5rem; font-size: 0.7rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 4px; text-transform: uppercase; background: #fef3c7; color: #92400e; }
  .stop-tag-trail { background: #dcfce7; color: #166534; }
  .stop-tag-services { background: #dbeafe; color: #1e40af; }

  .stop-highlight .stop-body { border-left: 4px solid var(--color-accent); }
  .stop-start .stop-body, .stop-end .stop-body { border-left: 4px solid var(--color-primary); }

  @media (max-width: 768px) {
    .stops-timeline::before { left: 20px; }
    .stop-km { min-width: 50px; font-size: 0.7rem; }
    .planner-summary { gap: 1.5rem; }
    .summary-num { font-size: 2rem; }
  }
</style>
