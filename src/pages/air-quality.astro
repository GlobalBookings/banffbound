---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Banff Air Quality & Wildfire Smoke Tracker — AQI & Smoke Forecast 2026" description="Real-time air quality and wildfire smoke information for Banff National Park. AQI scale explained, monthly smoke risk, what to do on smoky days, and links to official monitoring.">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'Is there wildfire smoke in Banff right now?', acceptedAnswer: { '@type': 'Answer', text: 'Check the current Banff air quality on Alberta\'s AQHI (Air Quality Health Index) website at airquality.alberta.ca or the firesmoke.ca forecast map. The Alberta AQHI updates hourly and rates air quality from 1 (low risk) to 10+ (very high risk). During wildfire season (July-September), smoke from BC and Alberta fires can drift into the Banff valley and reduce visibility significantly.' } },
      { '@type': 'Question', name: 'When is smoke season in Banff?', acceptedAnswer: { '@type': 'Answer', text: 'Wildfire smoke season in Banff typically runs from early July through late August, with September being moderate risk. The worst smoke usually comes from British Columbia wildfires carried east by prevailing winds. Some years have virtually no smoke, while others (like 2017, 2018, 2021, and 2023) had weeks of thick haze. June and October are very low risk.' } },
      { '@type': 'Question', name: 'What to do in Banff on smoky days?', acceptedAnswer: { '@type': 'Answer', text: 'On smoky days in Banff: 1) Switch to indoor activities — visit the Banff Upper Hot Springs, Cave and Basin, Whyte Museum, or shop on Banff Avenue. 2) Wear an N95 mask if outdoors. 3) Avoid strenuous exercise outside. 4) Drive to areas with clearer air — smoke can vary significantly even 30 minutes away. 5) Visit Banff Centre for performing arts or catch a movie at Lux Cinema. 6) Monitor firesmoke.ca for when conditions will improve.' } },
    ],
  })} />

  <div class="container">
    <Breadcrumbs items={[{ label: 'Air Quality & Smoke' }]} />
  </div>

  <section class="page-hero">
    <img src="https://images.unsplash.com/photo-1508193638397-1c4234db14d8?w=1600&q=80" alt="Mountain valley with atmospheric haze in the Canadian Rockies" class="page-hero-bg" loading="eager" fetchpriority="high" />
    <div class="page-hero-content">
      <span class="badge">Live Tracker</span>
      <h1>Air Quality &amp; Smoke Tracker</h1>
      <p>Wildfire smoke and air quality information for Banff — check before you hike, and know what to do on smoky days.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <div class="intro-block">
        <h2>Banff Air Quality: What Visitors Need to Know</h2>
        <p>Wildfire smoke can significantly impact your Banff trip, especially in July and August. Smoke drifts in from BC and Alberta wildfires, filling mountain valleys and reducing visibility. On bad smoke days, iconic views disappear and outdoor activities become unhealthy. Planning around smoke season — and knowing what to do when it hits — is essential.</p>
      </div>

      <div class="live-links">
        <h2>📡 Check Current Conditions</h2>
        <div class="link-cards">
          <a href="https://www.alberta.ca/air-quality-health-index" target="_blank" rel="noopener" class="link-card">
            <strong>Alberta AQHI</strong>
            <p>Official Air Quality Health Index — hourly updates for Banff</p>
          </a>
          <a href="https://firesmoke.ca/" target="_blank" rel="noopener" class="link-card">
            <strong>FireSmoke.ca</strong>
            <p>Smoke forecast maps — see where smoke is heading over the next 48 hours</p>
          </a>
          <a href="https://www.pc.gc.ca/en/pn-np/ab/banff/securite-safety/feu-fire" target="_blank" rel="noopener" class="link-card">
            <strong>Parks Canada Fire Info</strong>
            <p>Active fires, closures, and fire bans in Banff National Park</p>
          </a>
        </div>
      </div>

      <div class="aqi-section">
        <h2>🌡️ AQHI Scale Explained</h2>
        <p>Alberta uses the Air Quality Health Index (AQHI) rated 1-10+. Here's what each level means for your Banff plans:</p>
        <div class="aqi-scale">
          <div class="aqi-row low">
            <div class="aqi-range">1-3</div>
            <div class="aqi-label">Low Risk</div>
            <div class="aqi-desc">
              <strong>Ideal for all activities.</strong> Air quality is good. Enjoy hiking, biking, and all outdoor activities with no restrictions. Most days outside of smoke season fall here.
            </div>
          </div>
          <div class="aqi-row moderate">
            <div class="aqi-range">4-6</div>
            <div class="aqi-label">Moderate Risk</div>
            <div class="aqi-desc">
              <strong>Consider reducing prolonged outdoor exertion.</strong> Sensitive individuals (asthma, heart/lung conditions, elderly, young children) should limit strenuous outdoor activity. Short hikes and sightseeing are generally fine for healthy adults.
            </div>
          </div>
          <div class="aqi-row high">
            <div class="aqi-range">7-10</div>
            <div class="aqi-label">High Risk</div>
            <div class="aqi-desc">
              <strong>Reduce outdoor activities.</strong> Everyone should limit prolonged outdoor exertion. Visible haze; mountain views significantly reduced. Wear an N95 mask if going outside. Consider switching to indoor activities.
            </div>
          </div>
          <div class="aqi-row very-high">
            <div class="aqi-range">10+</div>
            <div class="aqi-label">Very High Risk</div>
            <div class="aqi-desc">
              <strong>Avoid outdoor activities.</strong> Everyone is at risk. Air smells strongly of smoke, visibility under 1 km. Stay indoors, close windows, use air purifiers if available. N95 mask essential for any outdoor exposure. Consider driving to clearer areas.
            </div>
          </div>
        </div>
      </div>

      <div class="monthly-section">
        <h2>📅 Monthly Smoke Risk</h2>
        <div class="month-grid">
          <div class="month-card minimal"><h3>January–May</h3><span class="risk-badge minimal">Minimal</span><p>Snow-covered landscape. Virtually zero wildfire smoke risk. Clear mountain air guaranteed.</p></div>
          <div class="month-card low"><h3>June</h3><span class="risk-badge low">Low</span><p>Fire season starts but rarely produces significant smoke in Banff. Occasional localized fires possible.</p></div>
          <div class="month-card high"><h3>July</h3><span class="risk-badge high">High</span><p>Peak wildfire season begins. BC fires often send smoke east into the Rockies. Multi-day smoke events possible.</p></div>
          <div class="month-card high"><h3>August</h3><span class="risk-badge high">Highest</span><p>Historically the worst month for smoke. 2017, 2018, 2021, and 2023 all had significant August smoke events lasting 1-3 weeks.</p></div>
          <div class="month-card moderate"><h3>September</h3><span class="risk-badge moderate">Moderate</span><p>Smoke risk decreases through the month. Early September can still be smoky. Late September usually clear with beautiful fall colours.</p></div>
          <div class="month-card minimal"><h3>October–December</h3><span class="risk-badge minimal">Minimal</span><p>Fire season over. Crystal clear mountain air returns. Best months for photography and visibility.</p></div>
        </div>
      </div>

      <div class="tips-section">
        <h2>💡 Tips for Smoky Days in Banff</h2>
        <div class="tips-grid">
          <div class="tip-card">
            <h3>🏛️ Go Indoors</h3>
            <p>Banff Upper Hot Springs, Cave and Basin, Whyte Museum, Banff Centre, Lux Cinema, shopping on Banff Avenue, spa treatments at hotel spas.</p>
          </div>
          <div class="tip-card">
            <h3>😷 Wear N95 Masks</h3>
            <p>Regular cloth masks don't filter wildfire particulates. N95 or KN95 masks are effective. Buy them at Banff pharmacies before they sell out.</p>
          </div>
          <div class="tip-card">
            <h3>📱 Monitor Forecasts</h3>
            <p>Check firesmoke.ca for 48-hour smoke forecasts. Smoke can clear in hours or linger for weeks. Wind direction changes everything.</p>
          </div>
          <div class="tip-card">
            <h3>🚗 Drive to Clearer Air</h3>
            <p>Smoke settles in valleys. Sometimes driving 30-60 minutes to higher elevations or different valleys can dramatically improve conditions.</p>
          </div>
          <div class="tip-card">
            <h3>🚫 Avoid Heavy Exertion</h3>
            <p>Skip the summit hikes and challenging trails on smoky days. Even healthy adults can develop respiratory irritation from prolonged activity in poor air quality.</p>
          </div>
          <div class="tip-card">
            <h3>📸 Unique Photography</h3>
            <p>Silver lining: smoky skies create dramatic sunrises and sunsets with vivid orange/red colours. Vermilion Lakes at sunset during moderate smoke can be spectacular.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .intro-block { max-width: 800px; margin: 0 auto 3rem; }
  .intro-block h2 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 1rem; }
  .intro-block p { color: var(--color-text-light); font-size: 1.05rem; line-height: 1.7; }

  .live-links { margin-bottom: 3rem; }
  .live-links h2 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 1.5rem; }

  .link-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .link-card {
    display: block;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-decoration: none;
    border: 2px solid transparent;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .link-card:hover { border-color: var(--color-accent); box-shadow: var(--shadow); }
  .link-card strong { display: block; color: var(--color-primary); font-size: 1.1rem; margin-bottom: 0.5rem; }
  .link-card p { color: var(--color-text-light); font-size: 0.9rem; margin: 0; line-height: 1.5; }

  .aqi-section { margin-bottom: 3rem; }
  .aqi-section h2 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 0.5rem; }
  .aqi-section > p { color: var(--color-text-light); margin-bottom: 1.5rem; }

  .aqi-scale { display: flex; flex-direction: column; gap: 1rem; }

  .aqi-row {
    display: grid;
    grid-template-columns: 80px 120px 1fr;
    align-items: start;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: var(--radius);
    border-left: 5px solid;
  }
  .aqi-row.low { background: #d4edda; border-color: #28a745; }
  .aqi-row.moderate { background: #fff3cd; border-color: #ffc107; }
  .aqi-row.high { background: #fde2d2; border-color: #fd7e14; }
  .aqi-row.very-high { background: #f8d7da; border-color: #dc3545; }

  .aqi-range { font-size: 1.4rem; font-weight: 700; font-family: var(--font-heading); }
  .aqi-label { font-weight: 600; font-size: 0.9rem; padding-top: 0.3rem; }
  .aqi-desc { font-size: 0.92rem; line-height: 1.6; }

  .monthly-section { margin-bottom: 3rem; }
  .monthly-section h2 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 1.5rem; }

  .month-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }

  .month-card {
    background: var(--color-white);
    border: 1px solid #e5e5e5;
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .month-card h3 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 0.5rem; font-size: 1.05rem; }
  .month-card p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.5; margin: 0; }

  .risk-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  .risk-badge.minimal { background: #d4edda; color: #155724; }
  .risk-badge.low { background: #d1ecf1; color: #0c5460; }
  .risk-badge.moderate { background: #fff3cd; color: #856404; }
  .risk-badge.high { background: #f8d7da; color: #721c24; }

  .tips-section { margin-bottom: 2rem; }
  .tips-section h2 { font-family: var(--font-heading); color: var(--color-primary); margin-bottom: 1.5rem; }

  .tips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }

  .tip-card {
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .tip-card h3 { font-size: 1rem; margin-bottom: 0.5rem; }
  .tip-card p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.5; margin: 0; }

  @media (max-width: 768px) {
    .aqi-row { grid-template-columns: 1fr; }
    .month-grid { grid-template-columns: 1fr; }
    .link-cards { grid-template-columns: 1fr; }
    .tips-grid { grid-template-columns: 1fr; }
  }
</style>
