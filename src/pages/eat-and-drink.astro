---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { restaurants as allRestaurants, drinkSpots as drinks, getRestaurantsByArea, type Area } from '../data/restaurants';

const areas: { key: Area; label: string; description: string }[] = [
  { key: 'Banff', label: 'Banff', description: 'Banff\'s dining scene is a delicious mix of fine dining, creative global kitchens, beloved local institutions, and award-winning casual eateries.' },
  { key: 'Lake Louise', label: 'Lake Louise', description: 'From refined Chateau dining rooms to cozy village cafes, Lake Louise offers a surprising range of culinary experiences amid some of the world\'s most stunning mountain scenery.' },
  { key: 'Canmore', label: 'Canmore', description: 'Just outside the park gates, Canmore\'s Main Street is packed with locally owned restaurants, craft breweries, and innovative kitchens that rival any mountain town in North America.' },
  { key: 'Highway 1A', label: 'Highway 1A & Castle Junction', description: 'Tucked into the forests along the Bow Valley Parkway, these wilderness dining gems offer romantic, candlelit meals in heritage lodges surrounded by towering pines.' },
];

const restaurantsByArea = areas.map(a => ({
  ...a,
  restaurants: getRestaurantsByArea(a.key),
}));
---

<BaseLayout title="Best Restaurants in Banff, Lake Louise & Canmore — Cafes, Breweries & Local Picks" description="The best restaurants, cafes, bars, and breweries in Banff, Lake Louise, Canmore, and the Bow Valley Parkway. From farm-to-table fine dining to cozy mountain pubs, craft breweries, and artisan bakeries.">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Best Restaurants in Banff, Lake Louise & Canmore',
    description: 'The best restaurants, cafes, bars, and breweries in Banff, Lake Louise, Canmore, and the Bow Valley Parkway.',
    url: 'https://banffbound.com/eat-and-drink',
    numberOfItems: allRestaurants.length,
    itemListElement: allRestaurants.map((r, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Restaurant',
        name: r.name,
        description: r.description,
        image: r.image,
        servesCuisine: r.cuisine,
        priceRange: r.priceRange,
        address: { '@type': 'PostalAddress', streetAddress: r.address, addressLocality: r.area, addressRegion: 'AB', addressCountry: 'CA' },
        telephone: r.phone,
        openingHours: r.hours,
        url: r.website,
        menu: r.menuUrl,
        geo: { '@type': 'GeoCoordinates', latitude: r.lat, longitude: r.lng },
      },
    })),
  })} />

  <div class="container">
    <Breadcrumbs items={[{ label: 'Eat & Drink' }]} />
  </div>
  <section class="page-hero">
    <img
      src="https://images.squarespace-cdn.com/content/v1/5c5c616477b903db9a5f3ee2/47e6ae83-11e3-4842-baad-2c7fed7be6e6/BISON-NOV-25.jpg?format=2500w"
      alt="Dining at The Bison Restaurant in Banff"
      class="page-hero-bg"
      loading="eager"
      fetchpriority="high"
    />
    <div class="page-hero-content">
      <span class="badge">Dine & Sip</span>
      <h1>Eat & Drink in Banff & Beyond</h1>
      <p>From elevated Rocky Mountain cuisine to cozy craft breweries, the Banff, Lake Louise, and Canmore dining scene punches well above its weight.</p>
    </div>
  </section>

  {restaurantsByArea.map((area, areaIdx) => (
    <section class="section" id={`restaurants-${area.key.toLowerCase().replace(/\s+/g, '-')}`} style={areaIdx % 2 === 1 ? 'background: var(--color-bg-alt);' : ''}>
      <div class="container">
        <div class="section-header">
          <span class="badge">{area.label} Restaurants</span>
          <h2>Where to Eat in {area.label}</h2>
          <p>{area.description}</p>
        </div>
        <div class="restaurant-list">
          {area.restaurants.map(item => (
            <div class="restaurant-card">
              <div class="restaurant-image-wrap">
                {item.image && <img src={item.image} alt={item.name} class="restaurant-image" loading="lazy" />}
                <div class="restaurant-price">{item.priceRange}</div>
              </div>
              <div class="restaurant-body">
                <div class="card-tags">
                  <span class="tag">{item.type}</span>
                  <span class="tag">{item.cuisine}</span>
                </div>
                <h3>{item.name}</h3>
                <p class="restaurant-desc">{item.description}</p>
                <div class="restaurant-highlights">
                  {item.highlights.map(h => (
                    <span class="highlight-chip">{h}</span>
                  ))}
                </div>
                <div class="restaurant-details">
                  <div class="detail-row">
                    <span class="detail-icon">&#128205;</span>
                    <span>{item.address}</span>
                  </div>
                  {item.phone && (
                    <div class="detail-row">
                      <span class="detail-icon">&#128222;</span>
                      <span>{item.phone}</span>
                    </div>
                  )}
                  {item.hours && (
                    <div class="detail-row">
                      <span class="detail-icon">&#128336;</span>
                      <span>{item.hours}</span>
                    </div>
                  )}
                </div>
                <div class="restaurant-actions">
                  {item.website && (
                    <a href={item.website} target="_blank" rel="noopener" class="btn btn-sm">Website</a>
                  )}
                  {item.menuUrl && (
                    <a href={item.menuUrl} target="_blank" rel="noopener" class="btn btn-sm btn-outline">Menu</a>
                  )}
                  {item.reserveUrl && (
                    <a href={item.reserveUrl} target="_blank" rel="noopener" class="btn btn-sm btn-gold">Reserve</a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container">
      <div class="section-header">
        <span class="badge">Bars, Breweries & Cafes</span>
        <h2>Where to Drink</h2>
        <p>Whether you need a craft cocktail after a day on the slopes, a perfect espresso before a morning hike, or a rooftop pint with mountain views.</p>
      </div>
      <div class="drink-list">
        {drinks.map(item => (
          <div class="drink-card-full">
            <div class="drink-image-wrap">
              <img src={item.image} alt={item.name} class="drink-image" loading="lazy" />
            </div>
            <div class="drink-body">
              <span class="tag">{item.type}</span>
              <h3>{item.name}</h3>
              <p>{item.description}</p>
              <div class="restaurant-details">
                <div class="detail-row">
                  <span class="detail-icon">&#128205;</span>
                  <span>{item.address}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-icon">&#128222;</span>
                  <span>{item.phone}</span>
                </div>
                <div class="detail-row">
                  <span class="detail-icon">&#128336;</span>
                  <span>{item.hours}</span>
                </div>
              </div>
              <div class="restaurant-actions">
                <a href={item.website} target="_blank" rel="noopener" class="btn btn-sm">Website</a>
                <a href={item.menuUrl} target="_blank" rel="noopener" class="btn btn-sm btn-outline">Menu</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background: var(--color-primary); color: var(--color-white); text-align: center;">
    <div class="container">
      <h2 style="color: var(--color-white); margin-bottom: 1rem;">Plan Your Banff Dining Trip</h2>
      <p style="opacity: 0.9; max-width: 600px; margin: 0 auto 2rem;">Book a food tour to discover Banff's best restaurants, or find the perfect hotel for your culinary getaway.</p>
      <a href="https://www.getyourguide.com/banff-l284/?partner_id=QW960HO&q=food" class="btn btn-accent" target="_blank" rel="noopener">Browse Food Tours on GetYourGuide →</a>
      <a href="https://www.expedia.ca/Hotel-Search?destination=Banff%2C+Alberta&camref=1101l3MtWX" class="btn btn-accent" target="_blank" rel="noopener sponsored" style="margin-left: 1rem;">Find Hotels on Expedia →</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="badge">Tip</span>
        <h2>Dining Tips for Banff</h2>
      </div>
      <div class="grid grid-3">
        <div class="tip-card">
          <h3>Reserve Ahead</h3>
          <p>Banff's best restaurants fill up fast, especially on weekends and during ski season. Book via OpenTable or call ahead for fine dining spots like The Bison, Juniper Bistro, and Park Distillery.</p>
        </div>
        <div class="tip-card">
          <h3>Bear Street is the Heart</h3>
          <p>Bear Street is Banff's foodie hub. Within two blocks you'll find Wild Flour Bakery, Nourish Bistro, Three Bears Brewery, Bear Street Tavern, and The Bison -- all walkable.</p>
        </div>
        <div class="tip-card">
          <h3>Happy Hour Culture</h3>
          <p>Nearly every bar offers daily happy hour specials. High Rollers does all-day happy hour Wednesdays, Three Bears runs 3-5pm daily, and Eddie Burger has all-day specials on Thursdays.</p>
        </div>
      </div>
    </div>
  </section>

<style>
  .card-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .restaurant-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .restaurant-card {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 2rem;
    background: var(--color-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: all var(--transition);
  }

  .restaurant-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .restaurant-image-wrap {
    position: relative;
    height: 100%;
    min-height: 280px;
  }

  .restaurant-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .restaurant-price {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 2rem;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .restaurant-body {
    padding: 1.5rem 1.5rem 1.5rem 0;
  }

  .restaurant-desc {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .restaurant-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .highlight-chip {
    background: var(--color-bg-alt);
    color: var(--color-text);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    font-size: 0.8rem;
    border: 1px solid var(--color-border, #e2e8f0);
  }

  .restaurant-details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .detail-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .detail-icon {
    font-size: 1rem;
    width: 1.2rem;
    text-align: center;
    flex-shrink: 0;
  }

  .restaurant-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-sm {
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
  }

  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: white;
  }

  .btn-gold {
    background: var(--color-accent);
    color: var(--color-text);
  }

  .btn-gold:hover {
    background: #c8991c;
    color: white;
  }

  .drink-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .drink-card-full {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 1.5rem;
    background: var(--color-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: all var(--transition);
  }

  .drink-card-full:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .drink-image-wrap {
    height: 100%;
    min-height: 220px;
  }

  .drink-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .drink-body {
    padding: 1.5rem 1.5rem 1.5rem 0;
  }

  .drink-body h3 {
    margin: 0.75rem 0 0.5rem;
  }

  .drink-body p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .tip-card {
    background: var(--color-white);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    border-top: 4px solid var(--color-accent);
  }

  .tip-card h3 {
    margin-bottom: 0.75rem;
  }

  .tip-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .restaurant-card {
      grid-template-columns: 1fr;
    }

    .restaurant-image-wrap {
      min-height: 200px;
      max-height: 220px;
    }

    .restaurant-body {
      padding: 1.25rem;
    }

    .drink-card-full {
      grid-template-columns: 1fr;
    }

    .drink-image-wrap {
      min-height: 180px;
      max-height: 200px;
    }

    .drink-body {
      padding: 1.25rem;
    }
  }
</style>
</BaseLayout>
