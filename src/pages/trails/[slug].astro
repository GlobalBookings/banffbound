---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { trails } from '../../data/trails';

const OWM_KEY_SSR = import.meta.env.PUBLIC_OWM_KEY || '';

export function getStaticPaths() {
  return trails.map(trail => ({
    params: { slug: trail.slug },
    props: { trail },
  }));
}

const { trail } = Astro.props;
const nearbyTrails = trails.filter(t => t.slug !== trail.slug && t.area === trail.area).slice(0, 4);

const difficultyColor = trail.difficulty === 'easy' ? '#166534' : trail.difficulty === 'moderate' ? '#92400e' : '#991b1b';
const difficultyBg = trail.difficulty === 'easy' ? '#dcfce7' : trail.difficulty === 'moderate' ? '#fef3c7' : '#fee2e2';

const safetyTips = [
  { icon: '🐻', text: 'Carry bear spray and know how to use it. Bears are active throughout Banff National Park.' },
  { icon: '📋', text: 'Check trail conditions on the Parks Canada website before heading out.' },
  { icon: '👥', text: 'Tell someone your hiking plan — where you\'re going and when you expect to return.' },
  { icon: '🧥', text: 'Bring layers. Mountain weather can change rapidly, even in summer.' },
  { icon: '💧', text: 'Carry at least 1 litre of water per person. There are no water stations on most trails.' },
];

const trailSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: trail.name,
  description: trail.description,
  image: trail.image,
  url: `https://banffbound.com/trails/${trail.slug}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: trail.area,
    addressRegion: 'Alberta',
    addressCountry: 'CA',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: trail.lat,
    longitude: trail.lng,
  },
  isAccessibleForFree: false,
  publicAccess: true,
  touristType: 'Hiking',
};
---

<BaseLayout title={`${trail.name} | Banff Trail Guide`} description={`Complete guide to ${trail.name} in ${trail.area}. ${trail.distance}, ${trail.elevationGain} elevation gain, ${trail.time}. Difficulty: ${trail.difficulty}.`}>

  <div class="container">
    <Breadcrumbs items={[
      { label: 'Trail Map', href: '/trail-map' },
      { label: trail.area, href: `/trail-map?area=${encodeURIComponent(trail.area)}` },
      { label: trail.name },
    ]} />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(trailSchema)} />

  <section class="trail-hero">
    <img src={trail.image} alt={trail.name} class="trail-hero-bg" loading="eager" fetchpriority="high" />
    <div class="trail-hero-overlay">
      <div class="container">
        <div class="hero-tags">
          <span class="difficulty-badge" style={`background:${difficultyBg};color:${difficultyColor};`}>{trail.difficulty}</span>
          <span class="badge">{trail.area}</span>
          <span class="type-tag">{trail.type}</span>
          {trail.status && trail.status !== 'unknown' && (
            <span class={`status-badge status-${trail.status}`}>
              {trail.status === 'open' ? '✓ Open' : trail.status === 'caution' ? '⚠ Caution' : '✕ Closed'}
            </span>
          )}
        </div>
        <h1>{trail.name}</h1>
        <p class="hero-desc">{trail.description}</p>
      </div>
    </div>
  </section>

  <div class="stats-bar">
    <div class="container stats-bar-inner">
      <div class="stat-item">
        <span class="stat-icon">📏</span>
        <span class="stat-label">Distance</span>
        <span class="stat-value">{trail.distance}</span>
      </div>
      <div class="stat-item">
        <span class="stat-icon">⬆️</span>
        <span class="stat-label">Elevation Gain</span>
        <span class="stat-value">{trail.elevationGain}</span>
      </div>
      <div class="stat-item">
        <span class="stat-icon">⬇️</span>
        <span class="stat-label">Elevation Loss</span>
        <span class="stat-value">{trail.elevationLoss}</span>
      </div>
      <div class="stat-item">
        <span class="stat-icon">⏱️</span>
        <span class="stat-label">Time</span>
        <span class="stat-value">{trail.time}</span>
      </div>
      <div class="stat-item">
        <span class="stat-icon">📅</span>
        <span class="stat-label">Season</span>
        <span class="stat-value">{trail.season}</span>
      </div>
      <div class="stat-item">
        <span class="stat-icon">🏔️</span>
        <span class="stat-label">Difficulty</span>
        <span class="stat-value" style={`color:${difficultyColor};`}>{trail.difficulty.charAt(0).toUpperCase() + trail.difficulty.slice(1)}</span>
      </div>
    </div>
  </div>

  {(trail.conditionNote || trail.parkingCapacity || trail.crowdLevel) && (
    <div class="conditions-bar">
      <div class="container conditions-bar-inner">
        {trail.conditionNote && (
          <div class="condition-item">
            <span class="condition-icon">📋</span>
            <div>
              <strong>Trail Conditions</strong>
              <span>{trail.conditionNote}</span>
              {trail.conditionUpdated && <small>Updated {trail.conditionUpdated}</small>}
            </div>
          </div>
        )}
        {trail.parkingCapacity && (
          <div class="condition-item">
            <span class="condition-icon">🅿️</span>
            <div>
              <strong>Parking</strong>
              <span>{trail.parkingCapacity}</span>
              {trail.parkingNotes && <small>{trail.parkingNotes}</small>}
            </div>
          </div>
        )}
        {trail.crowdLevel && (
          <div class="condition-item">
            <span class="condition-icon">👥</span>
            <div>
              <strong>Typical Crowds</strong>
              <span>Summer: {trail.crowdLevel.summer} · Winter: {trail.crowdLevel.winter}</span>
            </div>
          </div>
        )}
      </div>
    </div>
  )}

  <section class="section">
    <div class="container">
      <div class="trail-layout">
        <div class="trail-main">

          <div class="content-section">
            <h2>About This Trail</h2>
            {trail.longDescription.split('\n\n').map(paragraph => (
              <p class="trail-text">{paragraph}</p>
            ))}
          </div>

          <div class="content-section">
            <h2>Highlights</h2>
            <div class="highlights-list">
              {trail.highlights.map(h => (
                <span class="highlight-chip">{h}</span>
              ))}
            </div>
          </div>

          <div class="content-section">
            <h2>Trailhead Information</h2>
            <div class="trailhead-info">
              <div class="trailhead-row">
                <span class="trailhead-icon">📍</span>
                <div>
                  <strong>Starting Point</strong>
                  <p>{trail.trailhead}</p>
                </div>
              </div>
              {trail.transitAccessible && (
                <div class="trailhead-row">
                  <span class="trailhead-icon">🚌</span>
                  <div>
                    <strong>Transit Accessible</strong>
                    <p>{trail.transitRoute || 'Accessible by public transit'}</p>
                  </div>
                </div>
              )}
              {!trail.transitAccessible && (
                <div class="trailhead-row">
                  <span class="trailhead-icon">🚗</span>
                  <div>
                    <strong>Vehicle Required</strong>
                    <p>This trail is not accessible by public transit. A personal vehicle or taxi is required.</p>
                  </div>
                </div>
              )}
            </div>
          </div>

          <div class="content-section">
            <h2>Trail Location</h2>
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
            <div id="trail-detail-map" class="trail-map-embed"></div>
          </div>

          <div class="content-section">
            <h2>Safety Tips</h2>
            <div class="safety-list">
              {safetyTips.map(tip => (
                <div class="safety-item">
                  <span class="safety-icon">{tip.icon}</span>
                  <p>{tip.text}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="content-section">
            <div class="cta-box">
              <h3>Check Latest Trail Conditions</h3>
              <p>Always check the official Parks Canada page for current conditions, closures, and advisories before heading out.</p>
              <a href={trail.parksCanadaUrl} target="_blank" rel="noopener" class="btn btn-primary">
                View on Parks Canada →
              </a>
            </div>
          </div>
        </div>

        <div class="trail-sidebar">
          <div class="sidebar-card quick-facts">
            <h3>Quick Facts</h3>
            <div class="fact-row"><span>Distance</span><span>{trail.distance}</span></div>
            <div class="fact-row"><span>Elevation Gain</span><span>{trail.elevationGain}</span></div>
            <div class="fact-row"><span>Elevation Loss</span><span>{trail.elevationLoss}</span></div>
            <div class="fact-row"><span>Time</span><span>{trail.time}</span></div>
            <div class="fact-row"><span>Difficulty</span><span style={`color:${difficultyColor};font-weight:700;`}>{trail.difficulty.charAt(0).toUpperCase() + trail.difficulty.slice(1)}</span></div>
            <div class="fact-row"><span>Season</span><span>{trail.season}</span></div>
            <div class="fact-row"><span>Type</span><span style="text-transform:capitalize;">{trail.type}</span></div>
            <div class="fact-row"><span>Area</span><span>{trail.area}</span></div>
            <div class="fact-row"><span>Transit</span><span>{trail.transitAccessible ? 'Yes' : 'No'}</span></div>
          </div>

          <div class="sidebar-card sun-card">
            <h3>Sun & Golden Hour</h3>
            <div id="sun-data" class="sun-grid">
              <div class="sun-item"><span class="sun-label">Sunrise</span><span class="sun-value" id="sunrise-time">--</span></div>
              <div class="sun-item"><span class="sun-label">Sunset</span><span class="sun-value" id="sunset-time">--</span></div>
              <div class="sun-item"><span class="sun-label">Golden Hour</span><span class="sun-value" id="golden-hour">--</span></div>
              <div class="sun-item"><span class="sun-label">Daylight</span><span class="sun-value" id="daylight-hours">--</span></div>
            </div>
            <p class="sun-tip" id="sun-tip"></p>
          </div>

          <div class="sidebar-card gear-card">
            <h3>Gear Checklist</h3>
            <div class="gear-list" id="gear-list"></div>
          </div>

          <div class="sidebar-card hike-decision">
            <h3>Should I Hike Today?</h3>
            <div id="hike-verdict" class="hike-verdict">
              <div class="hike-loading"><div class="spinner-sm"></div><span>Checking conditions...</span></div>
            </div>
          </div>

          <div class="sidebar-card">
            <h3>Official Info</h3>
            <p style="font-size:0.85rem;color:var(--color-text-light);margin-bottom:0.75rem;">Get the latest trail conditions, closures, and safety updates.</p>
            <a href={trail.parksCanadaUrl} target="_blank" rel="noopener" class="btn btn-primary sidebar-btn">Parks Canada →</a>
          </div>

          <div class="sidebar-card">
            <h3>Explore More Trails</h3>
            <a href="/trail-map" class="btn btn-outline sidebar-btn">View All {trails.length} Trails →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {nearbyTrails.length > 0 && (
    <section class="section" style="background:var(--color-bg-alt);">
      <div class="container">
        <div class="section-header">
          <h2>More Trails in {trail.area}</h2>
          <p>Explore other trails and destinations nearby.</p>
        </div>
        <div class="grid grid-4">
          {nearbyTrails.map(t => (
            <a href={`/trails/${t.slug}`} class="card">
              <img src={t.image} alt={t.name} class="card-image" style="height:160px;" loading="lazy" />
              <div class="card-body">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">
                  <span class="nearby-difficulty" style={`background:${t.difficulty === 'easy' ? '#dcfce7' : t.difficulty === 'moderate' ? '#fef3c7' : '#fee2e2'};color:${t.difficulty === 'easy' ? '#166534' : t.difficulty === 'moderate' ? '#92400e' : '#991b1b'};`}>{t.difficulty}</span>
                  <span style="font-size:0.75rem;color:var(--color-text-light);text-transform:capitalize;">{t.type}</span>
                </div>
                <h3 style="font-size:0.95rem;">{t.name}</h3>
                <p style="font-size:0.8rem;color:var(--color-text-light);">📏 {t.distance} · ⬆️ {t.elevationGain} · ⏱️ {t.time}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script define:vars={{ lat: trail.lat, lng: trail.lng, name: trail.name, difficulty: trail.difficulty, season: trail.season, distance: trail.distance, elevationGain: trail.elevationGain, time: trail.time, status: trail.status || 'open', OWM_KEY: OWM_KEY_SSR }}>
  // ── Map ───────────────────────────────────────────
  function initTrailMap() {
    const mapEl = document.getElementById('trail-detail-map');
    if (!mapEl || typeof L === 'undefined') return;
    const map = L.map('trail-detail-map').setView([lat, lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors',
      maxZoom: 18,
    }).addTo(map);
    L.marker([lat, lng]).addTo(map).bindPopup(`<strong>${name}</strong>`).openPopup();
  }
  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = initTrailMap;
  document.head.appendChild(script);

  // ── Sunrise/Sunset Calculator (pure math, no API) ─
  function calcSun(lat, lng, date) {
    const rad = Math.PI / 180;
    const dayOfYear = Math.floor((date - new Date(date.getFullYear(),0,0)) / 86400000);
    const declination = 23.45 * Math.sin(rad * (360/365) * (dayOfYear - 81));
    const hourAngle = Math.acos(
      (-Math.tan(lat * rad) * Math.tan(declination * rad))
    ) / rad;
    const solarNoon = 12 - lng / 15;
    const offset = -7; // MST
    const sunrise = solarNoon - hourAngle / 15 - offset;
    const sunset = solarNoon + hourAngle / 15 - offset;
    return { sunrise, sunset };
  }

  function fmtTime(h) {
    const hours = Math.floor(h);
    const mins = Math.round((h - hours) * 60);
    const ampm = hours >= 12 ? 'PM' : 'AM';
    const h12 = hours > 12 ? hours - 12 : hours === 0 ? 12 : hours;
    return `${h12}:${mins.toString().padStart(2,'0')} ${ampm}`;
  }

  (function loadSun() {
    const now = new Date();
    const { sunrise, sunset } = calcSun(lat, lng, now);
    const daylight = sunset - sunrise;
    const goldenStart = sunset - 1;
    document.getElementById('sunrise-time').textContent = fmtTime(sunrise);
    document.getElementById('sunset-time').textContent = fmtTime(sunset);
    document.getElementById('golden-hour').textContent = `${fmtTime(goldenStart)} - ${fmtTime(sunset)}`;
    document.getElementById('daylight-hours').textContent = `${Math.floor(daylight)}h ${Math.round((daylight % 1) * 60)}m`;

    const hikeHours = parseFloat(time) || 3;
    const latestStart = sunset - hikeHours - 0.5;
    document.getElementById('sun-tip').textContent =
      `Start by ${fmtTime(latestStart)} to finish before dark (${hikeHours}hr hike + 30min buffer).`;
  })();

  // ── Gear Checklist ────────────────────────────────
  (function loadGear() {
    const month = new Date().getMonth();
    const isWinter = month >= 10 || month <= 3;
    const isSummer = month >= 5 && month <= 8;
    const elevNum = parseInt(elevationGain) || 0;
    const isHard = difficulty === 'challenging' || elevNum > 500;

    const gear = [
      { item: 'Water (1L+ per person)', always: true },
      { item: 'Bear spray', always: true },
      { item: 'Trail snacks / lunch', always: true },
      { item: 'Sunscreen & sunglasses', always: true },
      { item: 'First aid kit', always: true },
      { item: 'Map / downloaded trail', show: isHard },
      { item: 'Rain jacket', always: true },
      { item: 'Extra warm layer', show: isWinter || isHard },
      { item: 'Trekking poles', show: isHard || elevNum > 300 },
      { item: 'Headlamp', show: isHard },
      { item: 'Ice cleats / microspikes', show: isWinter || season === 'winter' },
      { item: 'Snowshoes', show: season === 'winter' },
      { item: 'Gaiters', show: isWinter && season === 'winter' },
      { item: 'Insulated water bottle', show: isWinter },
      { item: 'Bug spray', show: isSummer },
      { item: 'Hat & gloves', show: isWinter || isHard },
    ];

    const list = document.getElementById('gear-list');
    list.innerHTML = gear
      .filter(g => g.always || g.show)
      .map(g => `<label class="gear-item"><input type="checkbox" /><span>${g.item}</span></label>`)
      .join('');
  })();

  // ── Should I Hike Today? Decision Engine ──────────
  (async function hikeDecision() {
    const verdict = document.getElementById('hike-verdict');
    try {
      if (!OWM_KEY) throw new Error('No key');
      const res = await fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lng}&units=metric&appid=${OWM_KEY}`);
      if (!res.ok) throw new Error('API error');
      const wx = await res.json();

      const temp = Math.round(wx.main.temp);
      const wind = Math.round(wx.wind.speed * 3.6);
      const weatherMain = wx.weather[0].main;
      const desc = wx.weather[0].description;

      let score = 80;
      let factors = [];

      // Temperature scoring
      if (temp >= 5 && temp <= 20) { score += 10; factors.push(`${temp}°C is ideal hiking temperature`); }
      else if (temp < -15) { score -= 30; factors.push(`${temp}°C is dangerously cold`); }
      else if (temp < 0) { score -= 10; factors.push(`${temp}°C — dress in warm layers`); }
      else if (temp > 28) { score -= 15; factors.push(`${temp}°C — risk of heat exhaustion`); }

      // Weather conditions
      if (['Rain','Thunderstorm'].includes(weatherMain)) { score -= 25; factors.push(`${desc} — slippery trails, reduced visibility`); }
      if (weatherMain === 'Snow' && season !== 'winter') { score -= 20; factors.push('Unexpected snow on a non-winter trail'); }
      if (weatherMain === 'Clear' || weatherMain === 'Clouds') { score += 5; factors.push(`${desc} — good visibility`); }

      // Wind
      if (wind > 50) { score -= 20; factors.push(`Wind ${wind} km/h — dangerous on exposed ridges`); }
      else if (wind > 30) { score -= 10; factors.push(`Wind ${wind} km/h — breezy on exposed sections`); }

      // Trail status
      if (status === 'closed') { score = 0; factors.push('Trail is currently CLOSED'); }
      else if (status === 'caution') { score -= 15; factors.push('Trail advisory in effect — check conditions'); }

      // Difficulty in bad weather
      if (difficulty === 'challenging' && ['Rain','Snow','Thunderstorm'].includes(weatherMain)) {
        score -= 15; factors.push('Challenging trail in poor weather — extra caution needed');
      }

      score = Math.max(0, Math.min(100, score));

      let emoji, label, color;
      if (score >= 75) { emoji = '✓'; label = 'Great day to hike!'; color = '#166534'; }
      else if (score >= 50) { emoji = '~'; label = 'Doable with preparation'; color = '#92400e'; }
      else if (score >= 25) { emoji = '!'; label = 'Not ideal — proceed with caution'; color = '#c2410c'; }
      else { emoji = '✕'; label = 'Not recommended today'; color = '#991b1b'; }

      verdict.innerHTML = `
        <div class="hike-score" style="color:${color};">
          <span class="score-num">${score}</span>
          <span class="score-label">/100</span>
        </div>
        <p class="hike-label" style="color:${color};">${emoji} ${label}</p>
        <ul class="hike-factors">${factors.map(f => `<li>${f}</li>`).join('')}</ul>
        <p class="hike-current">${temp}°C · ${desc} · Wind ${wind} km/h</p>
      `;
    } catch {
      verdict.innerHTML = '<p class="hike-fallback">Weather unavailable — check conditions before heading out.</p>';
    }
  })();
</script>

<style>
  .status-badge {
    font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.6rem;
    border-radius: 4px; text-transform: uppercase; letter-spacing: 0.03em;
  }
  .status-open { background: #dcfce7; color: #166534; }
  .status-caution { background: #fef3c7; color: #92400e; }
  .status-closed { background: #fee2e2; color: #991b1b; }

  .conditions-bar {
    background: var(--color-bg-alt); border-bottom: 1px solid var(--border, rgba(0,0,0,0.08));
    padding: 1rem 0;
  }
  .conditions-bar-inner { display: flex; gap: 2rem; flex-wrap: wrap; }
  .condition-item { display: flex; gap: 0.6rem; align-items: flex-start; }
  .condition-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem; }
  .condition-item div { display: flex; flex-direction: column; gap: 0.1rem; }
  .condition-item strong { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-light); }
  .condition-item span { font-size: 0.9rem; color: var(--color-text); }
  .condition-item small { font-size: 0.75rem; color: var(--color-text-light); }

  .trail-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    overflow: hidden;
  }

  .trail-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trail-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    padding: 4rem 0 2rem;
    color: white;
  }

  .trail-hero-overlay h1 {
    color: white;
    margin-bottom: 0.5rem;
  }

  .hero-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .difficulty-badge {
    padding: 0.2rem 0.7rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .type-tag {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.8);
    text-transform: capitalize;
  }

  .hero-desc {
    font-size: 1.05rem;
    opacity: 0.9;
    max-width: 700px;
    line-height: 1.6;
  }

  .stats-bar {
    background: var(--color-primary);
    color: white;
    padding: 1rem 0;
    position: sticky;
    top: 60px;
    z-index: 50;
  }

  .stats-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-align: center;
    flex: 1;
    min-width: 80px;
  }

  .stat-icon { font-size: 1.1rem; }

  .stat-label {
    font-size: 0.7rem;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
  }

