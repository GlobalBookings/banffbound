---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { blogPosts } from '../../data/blogPosts';
import { blogContent as blogContentMain } from '../../data/blogContent';
import { blogContent3 } from '../../data/blogContent3';
import { blogRedirects } from '../../data/redirects.mjs';

const blogContent = { ...blogContentMain, ...blogContent3 };

export function getStaticPaths() {
  return blogPosts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const redirect = (blogRedirects as Record<string, string>)[post.slug];
if (redirect) return Astro.redirect(`/blog/${redirect}/`, 301);

const content = blogContent;
---

<BlogLayout
  title={post.title}
  description={post.description}
  date={post.date}
  lastUpdated={post.lastUpdated}
  category={post.category}
  image={post.image}
  readTime={post.readTime}
>
  <Fragment set:html={content[post.slug] || '<p>Content coming soon.</p>'} />
</BlogLayout>
