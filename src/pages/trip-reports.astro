---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Share Your Banff Trip Report" description="Been to Banff? Share your trip report to help fellow travellers plan their Canadian Rockies adventure. Tell us your highlights, tips, and favourite moments.">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Share Your Banff Trip Report',
    description: 'Been to Banff? Share your trip report to help fellow travellers plan their Canadian Rockies adventure.',
    url: 'https://banffbound.com/trip-reports',
    mainEntity: {
      '@type': 'ContactPage',
      name: 'Banff Trip Report Submission',
    },
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://banffbound.com' },
        { '@type': 'ListItem', position: 2, name: 'Trip Reports' },
      ],
    },
  })} />

  <div class="container">
    <Breadcrumbs items={[{ label: 'Trip Reports' }]} />
  </div>

  <section class="section">
    <div class="container report-content">
      <div class="report-intro">
        <span class="badge">Community</span>
        <h1>Share Your Banff Trip Report</h1>
        <p class="report-lead">Help fellow travellers plan their Banff adventure. Your experience, tips, and honest feedback make a real difference for people deciding what to do, where to stay, and how to make the most of their time in the Canadian Rockies.</p>
      </div>

      <div class="why-share">
        <div class="why-share-card">
          <span class="why-icon">🗺️</span>
          <div>
            <strong>Help others plan better</strong>
            <p>Your firsthand experience helps visitors know what to expect, what to skip, and what not to miss.</p>
          </div>
        </div>
        <div class="why-share-card">
          <span class="why-icon">💡</span>
          <div>
            <strong>Share insider tips</strong>
            <p>The best advice comes from people who've been there. Share the things guidebooks don't mention.</p>
          </div>
        </div>
        <div class="why-share-card">
          <span class="why-icon">⭐</span>
          <div>
            <strong>Be part of the community</strong>
            <p>Join fellow Banff lovers in building the most helpful resource for Canadian Rockies travellers.</p>
          </div>
        </div>
      </div>

      <form action="https://formspree.io/f/mjgzaoek" method="POST" class="report-form" id="trip-report-form">
        <h2>Your Trip Details</h2>

        <div class="form-row form-row-2">
          <div class="form-group">
            <label for="report-name">Your Name <span class="required">*</span></label>
            <input type="text" id="report-name" name="name" required placeholder="e.g. Sarah M." />
          </div>
          <div class="form-group">
            <label for="report-email">Email <span class="required">*</span></label>
            <input type="email" id="report-email" name="email" required placeholder="you@example.com" />
            <span class="form-hint">We won't publish this — only used if we have follow-up questions.</span>
          </div>
        </div>

        <div class="form-row form-row-3">
          <div class="form-group">
            <label for="report-dates">Trip Dates <span class="required">*</span></label>
            <input type="text" id="report-dates" name="trip_dates" required placeholder="e.g. July 10–15, 2025" />
          </div>
          <div class="form-group">
            <label for="report-days">Number of Days <span class="required">*</span></label>
            <select id="report-days" name="number_of_days" required>
              <option value="">Select…</option>
              <option value="1">1 day</option>
              <option value="2">2 days</option>
              <option value="3">3 days</option>
              <option value="4">4 days</option>
              <option value="5">5 days</option>
              <option value="6">6 days</option>
              <option value="7">7 days</option>
              <option value="8-10">8–10 days</option>
              <option value="11+">11+ days</option>
            </select>
          </div>
          <div class="form-group">
            <label for="report-season">Season Visited <span class="required">*</span></label>
            <select id="report-season" name="season_visited" required>
              <option value="">Select…</option>
              <option value="summer">Summer (Jun–Aug)</option>
              <option value="fall">Fall (Sep–Oct)</option>
              <option value="winter">Winter (Nov–Mar)</option>
              <option value="spring">Spring (Apr–May)</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label>Activities You Did <span class="required">*</span></label>
          <div class="checkbox-grid">
            <label class="checkbox-label"><input type="checkbox" name="activities" value="hiking" /> 🥾 Hiking</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="skiing" /> ⛷️ Skiing / Snowboarding</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="lake-visits" /> 🏔️ Lake Visits</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="scenic-drives" /> 🚗 Scenic Drives</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="wildlife-viewing" /> 🐻 Wildlife Viewing</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="gondola" /> 🚡 Banff Gondola</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="hot-springs" /> ♨️ Hot Springs</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="canoeing-kayaking" /> 🛶 Canoeing / Kayaking</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="dining" /> 🍽️ Dining Out</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="photography" /> 📷 Photography</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="camping" /> ⛺ Camping</label>
            <label class="checkbox-label"><input type="checkbox" name="activities" value="shopping" /> 🛍️ Shopping</label>
          </div>
        </div>

        <h2>Your Experience</h2>

        <div class="form-group">
          <label for="report-highlights">Trip Highlights <span class="required">*</span></label>
          <textarea id="report-highlights" name="highlights" rows="4" required placeholder="What were the best parts of your trip? Favourite trails, views, restaurants, experiences…"></textarea>
        </div>

        <div class="form-group">
          <label for="report-tips">Tips for Other Visitors</label>
          <textarea id="report-tips" name="tips" rows="4" placeholder="Anything you wish you'd known before going? Packing tips, timing advice, hidden gems…"></textarea>
        </div>

        <div class="form-row form-row-2">
          <div class="form-group">
            <label>Would You Visit Again? <span class="required">*</span></label>
            <div class="radio-group">
              <label class="radio-label"><input type="radio" name="visit_again" value="yes" required /> Yes, definitely</label>
              <label class="radio-label"><input type="radio" name="visit_again" value="maybe" /> Maybe</label>
              <label class="radio-label"><input type="radio" name="visit_again" value="no" /> Probably not</label>
            </div>
          </div>
          <div class="form-group">
            <label>Overall Rating <span class="required">*</span></label>
            <div class="star-rating" id="star-rating">
              <input type="hidden" name="rating" id="rating-value" value="" required />
              <button type="button" class="star" data-value="1" aria-label="1 star">★</button>
              <button type="button" class="star" data-value="2" aria-label="2 stars">★</button>
              <button type="button" class="star" data-value="3" aria-label="3 stars">★</button>
              <button type="button" class="star" data-value="4" aria-label="4 stars">★</button>
              <button type="button" class="star" data-value="5" aria-label="5 stars">★</button>
              <span class="star-label" id="star-label"></span>
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-accent submit-btn">Submit Trip Report &rarr;</button>
        <p class="form-disclaimer">By submitting, you agree that we may feature your report (anonymised by default) on BanffBound to help other travellers.</p>
      </form>

      <div class="form-success" id="form-success" style="display:none;">
        <div class="success-icon">✓</div>
        <h2>Thank You!</h2>
        <p>Your trip report has been submitted. We really appreciate you taking the time to help fellow Banff visitors.</p>
        <a href="/" class="btn btn-primary">Back to Homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Star rating interaction
  (function() {
    var stars = document.querySelectorAll('#star-rating .star');
    var input = document.getElementById('rating-value');
    var label = document.getElementById('star-label');
    var labels = ['', 'Poor', 'Fair', 'Good', 'Great', 'Amazing'];
    var currentRating = 0;

    stars.forEach(function(star) {
      star.addEventListener('click', function() {
        currentRating = parseInt(this.dataset.value);
        input.value = currentRating;
        label.textContent = labels[currentRating] || '';
        updateStars();
      });

      star.addEventListener('mouseenter', function() {
        var hoverVal = parseInt(this.dataset.value);
        stars.forEach(function(s) {
          s.classList.toggle('hover', parseInt(s.dataset.value) <= hoverVal);
        });
      });

      star.addEventListener('mouseleave', function() {
        stars.forEach(function(s) { s.classList.remove('hover'); });
      });
    });

    function updateStars() {
      stars.forEach(function(s) {
        s.classList.toggle('active', parseInt(s.dataset.value) <= currentRating);
      });
    }

    // Form submission: show success message
    var form = document.getElementById('trip-report-form');
    var success = document.getElementById('form-success');
    if (form) {
      form.addEventListener('submit', function(e) {
        // Validate rating
        if (!input.value) {
          e.preventDefault();
          label.textContent = 'Please select a rating';
          label.style.color = '#991b1b';
          return;
        }
        // Validate at least one activity
        var checked = form.querySelectorAll('input[name="activities"]:checked');
        if (checked.length === 0) {
          e.preventDefault();
          var actLabel = form.querySelector('.checkbox-grid').parentElement.querySelector('label');
          actLabel.style.color = '#991b1b';
          actLabel.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
      });
    }
  })();
</script>

<style>
  .report-content { max-width: 800px; }

  .report-intro { margin-bottom: 2rem; }
  .report-intro h1 { margin: 0.5rem 0; }
  .report-lead {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .why-share {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .why-share-card {
    display: flex;
    gap: 0.75rem;
    padding: 1.25rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
  }

  .why-icon { font-size: 1.5rem; flex-shrink: 0; padding-top: 0.1rem; }
  .why-share-card strong { display: block; margin-bottom: 0.25rem; font-size: 0.95rem; }
  .why-share-card p { font-size: 0.85rem; color: var(--color-text-light); line-height: 1.5; margin: 0; }

  /* Form */
  .report-form {
    background: var(--color-white);
    border-radius: var(--radius);
    padding: 2.5rem;
    box-shadow: var(--shadow);
  }

  .report-form h2 {
    font-size: 1.3rem;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-bg-alt);
  }

  .report-form h2:not(:first-of-type) {
    margin-top: 2rem;
  }

  .form-row {
    display: grid;
    gap: 1rem;
  }

  .form-row-2 { grid-template-columns: 1fr 1fr; }
  .form-row-3 { grid-template-columns: 1fr 1fr 1fr; }

  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
    color: var(--color-dark);
  }

  .required { color: #991b1b; }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.7rem 1rem;
    border: 2px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    background: var(--color-white);
    transition: border-color 0.2s ease;
    outline: none;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
  }

  .form-group textarea { resize: vertical; min-height: 100px; }

  .form-hint {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.3rem;
  }

  /* Checkboxes */
  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 400 !important;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .checkbox-label:hover {
    background: var(--color-bg-alt);
    border-color: var(--color-accent);
  }

  .checkbox-label input[type="checkbox"] {
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
  }

  /* Radio buttons */
  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 400 !important;
    cursor: pointer;
  }

  .radio-label input[type="radio"] {
    accent-color: var(--color-accent);
    width: 16px;
    height: 16px;
  }

  /* Star rating */
  .star-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .star {
    background: none;
    border: none;
    font-size: 2rem;
    color: rgba(0,0,0,0.15);
    cursor: pointer;
    transition: color 0.15s ease, transform 0.15s ease;
    padding: 0;
    line-height: 1;
  }

  .star:hover, .star.hover { color: var(--color-accent); transform: scale(1.15); }
  .star.active { color: var(--color-accent); }

  .star-label {
    margin-left: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .submit-btn {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
    font-size: 1.05rem;
    padding: 1rem;
  }

  .form-disclaimer {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.75rem;
  }

  /* Success state */
  .form-success {
    text-align: center;
    padding: 3rem;
    background: var(--color-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 auto 1.5rem;
  }

  .form-success h2 { margin-bottom: 0.5rem; }
  .form-success p { color: var(--color-text-light); margin-bottom: 1.5rem; }

  @media (max-width: 768px) {
    .why-share { grid-template-columns: 1fr; }
    .form-row-2, .form-row-3 { grid-template-columns: 1fr; }
    .report-form { padding: 1.5rem; }
    .checkbox-grid { grid-template-columns: 1fr; }
  }
</style>
