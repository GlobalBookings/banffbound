---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  mainEntity: {
    '@type': 'Person',
    name: 'Jack Chittenden',
    url: 'https://jack.me.uk',
    sameAs: ['https://linkedin.com/in/jackchittenden', 'https://www.strava.com/athletes/6717157'],
    jobTitle: 'Founder',
    worksFor: { '@type': 'Organization', name: 'BanffBound', url: 'https://banffbound.com' },
    description: 'Ultra runner, Ironman triathlete, skier, and mountain adventurer. Creator of BanffBound.',
  },
};
---

<BaseLayout title="About BanffBound — Who's Behind This Site" description="BanffBound is built by Jack Chittenden, an ultra runner, Ironman triathlete, and mountain sports addict who fell in love with the Canadian Rockies.">
  <div class="container">
    <Breadcrumbs items={[{ label: 'About' }]} />
  </div>

  <section class="about-hero">
    <div class="container">
      <h1>About BanffBound</h1>
      <p class="about-lead">Built by someone who'd rather be on a trail than behind a screen.</p>
    </div>
  </section>

  <section class="section">
    <div class="container about-content">
      <div class="about-grid">
        <div class="about-text">
          <h2>Who's behind this?</h2>
          <p>I'm <strong>Jack Chittenden</strong>. I run ultras, race Ironmans, ski anything with snow on it, and spend an unreasonable amount of time planning trips to mountains. Banff National Park is the place that got me properly hooked on the Canadian Rockies.</p>

          <p>I first visited Banff on a ski trip and ended up extending my stay three times. The combination of world-class skiing, trails that start right from town, and lakes that genuinely look fake in photos — it got under my skin. I've been back multiple times since, in every season, and I keep finding new routes, new spots, and new reasons to go back.</p>

          <p>BanffBound started because I was frustrated with the travel content I found online. Most Banff guides are written by people who've never laced up a hiking boot, let alone skinned up a slope at sunrise. They recycle the same TripAdvisor descriptions and slap affiliate links on everything. I wanted to build something more useful — a site with real trail data, honest hotel comparisons, and tools that actually help you plan a trip instead of just selling you one.</p>

          <h2>What I actually do here</h2>
          <p>I maintain the trail database (71 trails with GPS coordinates, elevation profiles, and seasonal conditions), the hotel directory (96 properties I've researched and compared), and the interactive tools like the Trip Builder and the weather-based activity recommender. When I'm on the ground in Banff, I update trail conditions, check out new restaurants, and test routes I haven't done before.</p>

          <p>I also work in digital marketing full-time through <a href="https://jack.me.uk" target="_blank" rel="noopener">Spires Digital</a>, so I know how the internet works and I know what makes a genuinely useful website versus a content farm. BanffBound is my attempt to be the former.</p>

          <h2>The adventure CV</h2>
          <ul class="adventure-list">
            <li><strong>Ironman New Zealand</strong> — full distance, March 2025</li>
            <li><strong>Lule&aring; Ice Marathon</strong> — running on a frozen sea in Sweden, February 2025</li>
            <li><strong>Mt Taranaki Summit</strong> — New Zealand, February 2025</li>
            <li><strong>Big Bear Ultra</strong> — mountain ultra, October 2024</li>
            <li><strong>Ironman 70.3 Weymouth</strong> — September 2023</li>
            <li><strong>Pilot in training</strong> — 50+ hours flight time logged</li>
          </ul>

          <p>When I'm not working or racing, I'm usually out with my dog Pepper, who is absolute chaos wrapped in curly fur but makes every adventure better.</p>

          <h2>How this site makes money</h2>
          <p>Transparency matters. BanffBound earns commission when you book hotels through our Expedia links or tours through GetYourGuide. This doesn't cost you anything extra — the prices are identical. It does mean I can keep this site running, the data updated, and the tools free to use. I only recommend things I'd genuinely suggest to a friend visiting Banff.</p>
        </div>
        <div class="about-sidebar">
          <div class="author-card">
            <div class="author-avatar">JC</div>
            <h3>Jack Chittenden</h3>
            <p class="author-tagline">Ultra runner. Ironman. Skier. Mountain addict.</p>
            <div class="author-links">
              <a href="https://jack.me.uk" target="_blank" rel="noopener">jack.me.uk</a>
              <a href="https://linkedin.com/in/jackchittenden" target="_blank" rel="noopener">LinkedIn</a>
              <a href="https://www.strava.com/athletes/6717157" target="_blank" rel="noopener">Strava</a>
            </div>
          </div>
          <div class="about-stats">
            <div class="stat-item">
              <span class="stat-number">71</span>
              <span class="stat-label">Trails Documented</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">96</span>
              <span class="stat-label">Hotels Reviewed</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">265+</span>
              <span class="stat-label">Travel Guides</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />
</BaseLayout>

<style>
  .about-hero { padding: 4rem 0 2rem; }
  .about-hero h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 0.5rem; }
  .about-lead { font-size: 1.2rem; color: var(--color-text-light); max-width: 600px; }

  .about-grid { display: grid; grid-template-columns: 1fr 320px; gap: 4rem; align-items: start; }
  .about-text h2 { margin: 2.5rem 0 1rem; font-size: 1.5rem; }
  .about-text h2:first-child { margin-top: 0; }
  .about-text p { line-height: 1.8; margin-bottom: 1rem; color: var(--color-text); }
  .about-text a { color: var(--color-primary); text-decoration: underline; }

  .adventure-list { margin: 1rem 0 1.5rem 1.5rem; line-height: 1.8; }
  .adventure-list li { margin-bottom: 0.5rem; }

  .author-card {
    background: var(--color-bg-alt); border-radius: var(--radius); padding: 2rem;
    text-align: center; position: sticky; top: 2rem;
  }
  .author-avatar {
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--color-primary); color: var(--color-white);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; font-weight: 700; margin: 0 auto 1rem;
    font-family: var(--font-heading);
  }
  .author-card h3 { margin-bottom: 0.25rem; }
  .author-tagline { font-size: 0.85rem; color: var(--color-text-light); margin-bottom: 1rem; }
  .author-links { display: flex; flex-direction: column; gap: 0.4rem; }
  .author-links a { font-size: 0.85rem; color: var(--color-primary); text-decoration: underline; }

  .about-stats {
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-top: 1.5rem;
    background: var(--color-bg-alt); border-radius: var(--radius); padding: 1.5rem;
  }
  .stat-item { text-align: center; }
  .stat-number { display: block; font-size: 1.5rem; font-weight: 700; color: var(--color-primary); font-family: var(--font-heading); }
  .stat-label { font-size: 0.7rem; color: var(--color-text-light); text-transform: uppercase; letter-spacing: 0.05em; }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .author-card { position: static; }
  }
</style>
