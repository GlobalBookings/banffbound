---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { activities, tripTemplates, hotelLink } from '../data/tripActivities';
import { trails } from '../data/trails';

const OWM_KEY_SSR = import.meta.env.PUBLIC_OWM_KEY || '';
const activityMap = Object.fromEntries(activities.map(a => [a.id, a]));

const trailConditions = trails.filter(t => t.status && t.status !== 'open').map(t => ({
  name: t.name, slug: t.slug, status: t.status, note: t.conditionNote || '',
}));
const closedTrailNames = new Set(trails.filter(t => t.status === 'closed').map(t => t.name.toLowerCase()));
---

<BaseLayout title="Trip Builder" description="Plan your perfect Banff trip day by day. Choose a template or build your own itinerary with booking links for tours, hotels, and activities.">

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'TouristTrip',
    name: 'Banff Trip Builder — Plan Your Perfect Itinerary',
    description: 'Plan your perfect Banff trip day by day. Choose a template or build your own itinerary with booking links for tours, hotels, and activities.',
    url: 'https://banffbound.com/trip-builder',
    touristType: ['Adventure travelers', 'Families', 'Couples', 'Solo travelers'],
    itinerary: {
      '@type': 'ItemList',
      name: 'Banff Trip Templates',
      numberOfItems: tripTemplates.length,
      itemListElement: tripTemplates.map((tmpl, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'Trip',
          name: tmpl.name,
          description: tmpl.description,
        },
      })),
    },
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'CAD',
      description: 'Free trip planning tool',
    },
  })} />

  <div class="container">
    <Breadcrumbs items={[{ label: 'Trip Builder' }]} />
  </div>
  <section class="page-hero">
    <img src="https://images.unsplash.com/photo-1609198092458-38a293c7ac4b?w=1600&q=80" alt="Banff National Park" class="page-hero-bg" loading="eager" fetchpriority="high" />
    <div class="page-hero-content">
      <span class="badge">Plan Your Trip</span>
      <h1>Banff Trip Builder</h1>
      <p>Choose a ready-made itinerary or build your own. Every activity includes booking links so you can secure your spots.</p>
    </div>
  </section>

  <!-- Live Conditions Banner -->
  <section class="conditions-banner" id="conditions-banner" style="display:none;">
    <div class="container">
      <div class="conditions-inner">
        <div class="conditions-weather" id="conditions-weather"></div>
        {trailConditions.length > 0 && (
          <div class="conditions-alerts">
            <strong>Trail Alerts:</strong>
            {trailConditions.map(t => (
              <a href={`/trails/${t.slug}`} class={`alert-chip alert-${t.status}`}>
                {t.status === 'closed' ? '✕' : '⚠'} {t.name}
                {t.note && <span class="alert-note"> — {t.note}</span>}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Template Selector -->
  <section class="templates-section">
    <div class="container">
      <div class="section-header">
        <h2>Choose Your Adventure</h2>
        <p>Pick a template that matches your style, then customize it to fit your trip.</p>
      </div>
      <div class="templates-grid">
        {tripTemplates.map((tmpl, i) => (
          <button class="template-card" data-template={tmpl.id} data-index={i}>
            <span class="template-style">{tmpl.style}</span>
            <h3>{tmpl.name}</h3>
            <p>{tmpl.description}</p>
            <div class="template-meta">
              <span>{tmpl.days} Days</span>
              <span>&middot;</span>
              <span>{tmpl.season === 'all' ? 'Year-round' : tmpl.season === 'summer' ? 'Summer' : 'Winter'}</span>
            </div>
          </button>
        ))}
      </div>
      <div class="clear-selection-wrap" id="clear-selection-wrap" style="display:none;">
        <button class="btn btn-outline clear-selection-btn" id="clear-selection-btn">✕ Clear Saved Selection</button>
      </div>
    </div>
  </section>

  <!-- Share toast -->
  <div class="share-toast" id="share-toast" aria-live="polite">Link copied!</div>

  <!-- Itineraries (all rendered, shown/hidden via JS) -->
  {tripTemplates.map((tmpl, i) => (
    <section class="itinerary-section" data-itinerary={tmpl.id} style="display:none;">
      <div class="container">
        <div class="itinerary-header">
          <div>
            <span class="badge">{tmpl.style}</span>
            <h2>{tmpl.name}</h2>
            <p>{tmpl.description}</p>
          </div>
          <div class="itinerary-actions">
            <button class="btn btn-outline change-template-btn">Change Template</button>
            <button class="btn btn-outline share-btn" aria-label="Share this itinerary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Share Itinerary
            </button>
            <button class="btn btn-outline print-btn" aria-label="Print this itinerary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Print Itinerary
            </button>
          </div>
        </div>

        {tmpl.itinerary.map((day) => {
          const dayActivities = day.activityIds.map(id => activityMap[id]).filter(Boolean);
          const bookable = dayActivities.filter(a => a.bookingUrl);
          return (
            <div class="day-block">
              <div class="day-header">
                <h3>{day.dayLabel}</h3>
                <span class="day-count">{dayActivities.length} activities</span>
              </div>

              <div class="day-activities">
                {dayActivities.map(act => (
                  <div class="activity-card">
                    <div class="activity-icon">{act.icon}</div>
                    <div class="activity-info">
                      <div class="activity-top">
                        <strong>{act.name}</strong>
                        {act.price && <span class="activity-price">{act.price}</span>}
                      </div>
                      <p>{act.description}</p>
                      <div class="activity-tags">
                        <span class="tag">{act.duration}</span>
                        <span class="tag">{act.difficulty}</span>
                        <span class="tag">{act.timeOfDay}</span>
                      </div>
                      {act.bookingUrl && (
                        <a href={act.bookingUrl} target="_blank" rel="noopener" class="book-btn">
                          Book Now &rarr;
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>

              <div class="hotel-box">
                <div class="hotel-box-content">
                  <span class="hotel-icon">&#127968;</span>
                  <div>
                    <strong>Need a place to stay?</strong>
                    <p>Compare Banff hotels for this night on Expedia.</p>
                  </div>
                </div>
                <div class="hotel-links">
                  <a href={hotelLink('budget')} target="_blank" rel="noopener" class="hotel-link">Budget $</a>
                  <a href={hotelLink('mid')} target="_blank" rel="noopener" class="hotel-link">Mid-Range $$</a>
                  <a href={hotelLink('luxury')} target="_blank" rel="noopener" class="hotel-link">Luxury $$$</a>
                </div>
              </div>
            </div>
          );
        })}

        <!-- Summary -->
        <div class="trip-summary">
          <div class="summary-stats">
            <div class="summary-stat">
              <span class="summary-number">{tmpl.days}</span>
              <span>Days</span>
            </div>
            <div class="summary-stat">
              <span class="summary-number">{tmpl.itinerary.reduce((acc, d) => acc + d.activityIds.length, 0)}</span>
              <span>Activities</span>
            </div>
            <div class="summary-stat">
              <span class="summary-number">{tmpl.itinerary.reduce((acc, d) => acc + d.activityIds.filter(id => activityMap[id]?.bookingUrl).length, 0)}</span>
              <span>Bookable Tours</span>
            </div>
          </div>
          <div class="summary-ctas">
            <a href={`https://www.getyourguide.com/banff-l284/?partner_id=QW960HO`} target="_blank" rel="noopener" class="btn btn-accent">Browse All Banff Tours &rarr;</a>
            <a href={hotelLink('mid')} target="_blank" rel="noopener" class="btn btn-primary">Find Hotels on Expedia &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<script define:vars={{ OWM_KEY: OWM_KEY_SSR }}>
  const STORAGE_KEY = 'bb-trip-template';
  const templateCards = document.querySelectorAll('.template-card');
  const itineraries = document.querySelectorAll('.itinerary-section');
  const templatesSection = document.querySelector('.templates-section');
  const changeBtns = document.querySelectorAll('.change-template-btn');
  const shareBtns = document.querySelectorAll('.share-btn');
  const printBtns = document.querySelectorAll('.print-btn');
  const clearWrap = document.getElementById('clear-selection-wrap');
  const clearBtn = document.getElementById('clear-selection-btn');
  const shareToast = document.getElementById('share-toast');

  let activeTemplateId = null;

  // Load live weather into conditions banner
  (async function loadTripWeather() {
    try {
      if (!OWM_KEY) return;
      const [banffRes, forecastRes] = await Promise.all([
        fetch(`https://api.openweathermap.org/data/2.5/weather?lat=51.1784&lon=-115.5708&units=metric&appid=${OWM_KEY}`),
        fetch(`https://api.openweathermap.org/data/2.5/forecast?lat=51.1784&lon=-115.5708&units=metric&appid=${OWM_KEY}`),
      ]);
      if (!banffRes.ok) return;
      const wx = await banffRes.json();
      const fc = forecastRes.ok ? await forecastRes.json() : null;

      const temp = Math.round(wx.main.temp);
      const desc = wx.weather[0].description;
      const icon = wx.weather[0].icon;
      const wind = Math.round(wx.wind.speed * 3.6);

      let forecastHtml = '';
      if (fc) {
        const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const dailyMap = {};
        for (const item of fc.list) {
          const d = new Date(item.dt * 1000);
          const key = d.toISOString().split('T')[0];
          if (key === new Date().toISOString().split('T')[0]) continue;
          if (!dailyMap[key]) dailyMap[key] = { temps: [], icons: [], date: d };
          dailyMap[key].temps.push(item.main.temp);
          dailyMap[key].icons.push(item.weather[0].icon);
        }
        const entries = Object.values(dailyMap).slice(0, 3);
        forecastHtml = '<div class="trip-forecast">' + entries.map(day => {
          const hi = Math.round(Math.max(...day.temps));
          const lo = Math.round(Math.min(...day.temps));
          const midIcon = day.icons[Math.floor(day.icons.length / 2)];
          return `<span class="fc-day">${days[day.date.getDay()]} <img src="https://openweathermap.org/img/wn/${midIcon}.png" width="24" height="24" alt="" /> ${hi}°/${lo}°</span>`;
        }).join('') + '</div>';
      }

      const banner = document.getElementById('conditions-banner');
      const weatherEl = document.getElementById('conditions-weather');
      weatherEl.innerHTML = `
        <div class="trip-wx-now">
          <img src="https://openweathermap.org/img/wn/${icon}.png" width="36" height="36" alt="${desc}" />
          <span><strong>${temp}°C</strong> ${desc} · Wind ${wind} km/h</span>
        </div>
        ${forecastHtml}
      `;
      banner.style.display = 'block';
    } catch {}
  })();

  function showTemplate(id, saveToStorage) {
    itineraries.forEach(s => s.style.display = 'none');
    const target = document.querySelector(`[data-itinerary="${id}"]`);
    if (target) {
      activeTemplateId = id;
      target.style.display = 'block';
      templatesSection.style.display = 'none';
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (saveToStorage !== false) {
        try { localStorage.setItem(STORAGE_KEY, id); } catch {}
      }
      updateClearBtn();
    }
  }

  function showSelector() {
    activeTemplateId = null;
    itineraries.forEach(s => s.style.display = 'none');
    templatesSection.style.display = 'block';
    templatesSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    updateClearBtn();
  }

  function updateClearBtn() {
    try {
      var saved = localStorage.getItem(STORAGE_KEY);
      if (clearWrap) clearWrap.style.display = saved ? 'flex' : 'none';
    } catch {
      if (clearWrap) clearWrap.style.display = 'none';
    }
  }

  // Template card click
  templateCards.forEach(card => {
    card.addEventListener('click', () => {
      const id = card.dataset.template || '';
      showTemplate(id);
    });
  });

  // Change template buttons
  changeBtns.forEach(btn => btn.addEventListener('click', showSelector));

  // Share button — copy URL with ?template= param
  shareBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!activeTemplateId) return;
      const url = new URL(window.location.href);
      url.searchParams.set('template', activeTemplateId);
      url.hash = '';
      navigator.clipboard.writeText(url.toString()).then(() => {
        if (shareToast) {
          shareToast.classList.add('show');
          setTimeout(() => shareToast.classList.remove('show'), 2500);
        }
      }).catch(() => {
        // Fallback for older browsers
        var ta = document.createElement('textarea');
        ta.value = url.toString();
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        if (shareToast) {
          shareToast.classList.add('show');
          setTimeout(() => shareToast.classList.remove('show'), 2500);
        }
      });
    });
  });

  // Print button
  printBtns.forEach(btn => {
    btn.addEventListener('click', () => window.print());
  });

  // Clear selection button
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      try { localStorage.removeItem(STORAGE_KEY); } catch {}
      showSelector();
    });
  }

  // On page load: check URL params first, then localStorage
  (function restoreSelection() {
    const params = new URLSearchParams(window.location.search);
    const urlTemplate = params.get('template');
    if (urlTemplate) {
      const exists = document.querySelector(`[data-itinerary="${urlTemplate}"]`);
      if (exists) {
        showTemplate(urlTemplate);
        return;
      }
    }
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        const exists = document.querySelector(`[data-itinerary="${saved}"]`);
        if (exists) {
          showTemplate(saved, false);
          return;
        }
      }
    } catch {}
    updateClearBtn();
  })();
</script>

<style>
  /* Conditions banner */
  .conditions-banner { background: var(--color-bg-alt); border-bottom: 1px solid rgba(0,0,0,0.06); padding: 1rem 0; }
  .conditions-inner { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; }
  .trip-wx-now { display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; }
  .trip-forecast { display: flex; gap: 0.75rem; }
  .fc-day { display: flex; align-items: center; gap: 0.2rem; font-size: 0.8rem; color: var(--color-text-light); background: var(--color-white); padding: 0.25rem 0.5rem; border-radius: 4px; }
  .conditions-alerts { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.85rem; }
  .conditions-alerts strong { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-light); }
  .alert-chip { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.78rem; padding: 0.2rem 0.5rem; border-radius: 4px; text-decoration: none; }
  .alert-closed { background: #fee2e2; color: #991b1b; }
  .alert-caution { background: #fef3c7; color: #92400e; }
  .alert-note { font-weight: 400; }

  .templates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .template-card {
    background: var(--color-white);
    border: 2px solid transparent;
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: var(--shadow);
    font-family: var(--font-body);
  }

  .template-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .template-style {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .template-card h3 { margin-bottom: 0.5rem; font-size: 1.15rem; }
  .template-card p { color: var(--color-text-light); font-size: 0.9rem; margin-bottom: 0.75rem; }

  .template-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .itinerary-section { padding: 3rem 0; }

  .itinerary-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    gap: 1rem;
  }

  .itinerary-header h2 { margin: 0.25rem 0; }
  .itinerary-header p { color: var(--color-text-light); }

  .day-block {
    margin-bottom: 2.5rem;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .day-header {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .day-header h3 { color: var(--color-white); margin: 0; font-family: var(--font-body); font-size: 1rem; }
  .day-count { font-size: 0.85rem; opacity: 0.8; }

  .day-activities { padding: 1rem; }

  .activity-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .activity-card:hover { background: var(--color-bg-alt); }

  .activity-icon { font-size: 1.8rem; flex-shrink: 0; padding-top: 0.15rem; }

  .activity-info { flex: 1; }

  .activity-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .activity-price {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .activity-info p {
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .activity-tags { display: flex; gap: 0.4rem; margin-bottom: 0.5rem; }

  .book-btn {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .book-btn:hover { background: var(--color-primary); }

  .hotel-box {
    background: var(--color-bg-alt);
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hotel-box-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hotel-icon { font-size: 1.5rem; }
  .hotel-box-content p { font-size: 0.85rem; color: var(--color-text-light); margin: 0; }

  .hotel-links { display: flex; gap: 0.5rem; }

  .hotel-link {
    padding: 0.4rem 0.8rem;
    background: var(--color-white);
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-primary);
    transition: all 0.2s;
  }

  .hotel-link:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
  }

  .trip-summary {
    background: var(--color-white);
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .summary-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-bottom: 1.5rem;
  }

  .summary-stat { display: flex; flex-direction: column; align-items: center; }

  .summary-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .summary-stat span:last-child {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .summary-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .templates-section { padding: 3rem 0; }

  /* Itinerary action buttons */
  .itinerary-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .share-btn, .print-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    padding: 0.6rem 1rem;
  }

  .share-btn svg, .print-btn svg { flex-shrink: 0; }

  /* Clear selection */
  .clear-selection-wrap {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .clear-selection-btn {
    font-size: 0.85rem;
    padding: 0.5rem 1.2rem;
    color: var(--color-text-light);
    border-color: rgba(0,0,0,0.15);
  }

  .clear-selection-btn:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Share toast */
  .share-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--color-primary);
    color: var(--color-white);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 600;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 1000;
    pointer-events: none;
  }

  .share-toast.show {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 768px) {
    .itinerary-header { flex-direction: column; }
