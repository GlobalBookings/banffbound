---
// Expedia affiliate car-rental CTA.
const CAR_RENTAL_URL = 'https://expedia.com/affiliate/KB6G4xt';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Renting a Car for Banff?',
  text = 'Banff has no Uber and limited transit. A car is the easiest way to reach the lakes, trailheads, and viewpoints on your own schedule. Compare rental deals at Calgary Airport on Expedia.',
} = Astro.props;
---

<section class="car-cta">
  <div class="car-cta-icon">🚗</div>
  <div class="car-cta-body">
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={CAR_RENTAL_URL} target="_blank" rel="noopener sponsored" class="car-cta-btn">
      Search Car Rentals on Expedia &rarr;
    </a>
  </div>
</section>

<style>
  .car-cta {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    margin: 2.5rem 0;
    padding: 1.75rem;
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, #f0f7f4 100%);
    border: 1px solid rgba(0,0,0,0.06);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
  }
  .car-cta-icon { font-size: 2rem; flex-shrink: 0; }
  .car-cta-body h2 { font-size: 1.15rem; margin-bottom: 0.4rem; color: var(--color-primary); }
  .car-cta-body p { font-size: 0.88rem; color: var(--color-text-light); line-height: 1.55; margin-bottom: 1rem; }
  .car-cta-btn {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.88rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    transition: background 0.15s, transform 0.15s;
  }
  .car-cta-btn:hover { background: var(--color-primary); transform: translateY(-1px); }
  @media (max-width: 768px) {
    .car-cta { flex-direction: column; gap: 0.75rem; padding: 1.25rem; }
  }
</style>
