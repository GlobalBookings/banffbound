---
const currentPath = Astro.url.pathname;

const megaMenus = {
  'Things To Do': {
    links: [
      { href: '/activities', label: 'Activities' },
      { href: '/hiking', label: 'Hiking' },
      { href: '/skiing', label: 'Skiing & Snowboarding' },
      { href: '/trail-map', label: 'Trail Map' },
      { href: '/lakes', label: 'Lakes' },
      { href: '/paddling', label: 'Paddling' },
      { href: '/biking', label: 'Biking' },
      { href: '/scenic-drives', label: 'Scenic Drives' },
      { href: '/wildlife', label: 'Wildlife' },
      { href: '/wellness', label: 'Wellness & Spas' },
      { href: '/arts-culture', label: 'Arts & Culture' },
      { href: '/shopping', label: 'Shopping' },
      { href: '/eat-and-drink', label: 'Eat & Drink' },
      { href: '/events', label: 'Events & Festivals' },
      { href: '/tours', label: 'Tours & Experiences' },
    ],
    featured: [
      { href: '/trail-map', image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=400&q=75&fm=webp', title: 'Interactive Trail Map', subtitle: '70+ trails to explore' },
      { href: '/eat-and-drink', image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=400&q=75&fm=webp', title: 'Eat & Drink', subtitle: 'Restaurants, bars & cafes' },
      { href: '/lakes', image: 'https://images.unsplash.com/photo-1503614472-8c93d56e92ce?w=400&q=75&fm=webp', title: 'Iconic Lakes', subtitle: 'Lake Louise, Moraine & more' },
    ],
  },
  'Visitor Info': {
    links: [
      { href: '/banff-national-park', label: 'About Banff National Park' },
      { href: '/weather-webcams', label: 'Weather & Webcams' },
      { href: '/summer', label: 'Summer in Banff' },
      { href: '/winter', label: 'Winter in Banff' },
      { href: '/what-to-do-today', label: 'What To Do Today' },
      { href: '/currency-converter', label: 'Currency Converter' },
      { href: '/trip-reports', label: 'Trip Reports' },
      { href: 'https://parks.canada.ca/pn-np/ab/banff/visit/pass', label: 'Buy Your Park Pass', external: true },
      { href: '/locals', label: 'Locals Guide' },
      { href: '/packing-list', label: '🎒 Pack for Banff — Gear Checklist', cta: true },
    ],
    featured: [
      { href: '/weather-webcams', image: 'https://images.unsplash.com/photo-1609198092458-38a293c7ac4b?w=400&q=75&fm=webp', title: 'Weather & Webcams', subtitle: 'Live conditions & cameras' },
      { href: '/packing-list', image: 'https://images.unsplash.com/photo-1491002052546-bf38f186af56?w=400&q=75&fm=webp', title: 'Packing List', subtitle: 'Seasonal gear with Amazon links' },
      { href: '/what-to-do-today', image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&q=75&fm=webp', title: 'What To Do Today', subtitle: 'Weather-based suggestions' },
    ],
  },
  'Where To Stay': {
    links: [
      { href: '/hotel-directory', label: 'All Hotels & Lodges' },
      { href: '/vacation-rentals', label: 'Vacation Rentals & Cabins' },
      { href: '/hotel-directory?area=Downtown+Banff', label: 'Hotels in Downtown Banff' },
      { href: '/hotel-directory?area=Tunnel+Mountain', label: 'Hotels on Tunnel Mountain' },
      { href: '/hotel-directory?area=Lake+Louise', label: 'Hotels in Lake Louise' },
      { href: '/hotel-directory?area=Canmore', label: 'Hotels in Canmore' },
      { href: '/hotel-directory?type=Resort', label: 'Resorts' },
      { href: '/hotel-directory?type=Lodge', label: 'Lodges & Cabins' },
      { href: '/hotel-directory?type=Hostel', label: 'Hostels & Budget' },
    ],
    featured: [
      { href: '/hotel-directory', image: 'https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=400&q=75&fm=webp', title: 'Hotel Directory', subtitle: '95 properties with map' },
      { href: '/hotel-directory?area=Lake+Louise', image: 'https://images.unsplash.com/photo-1454496522488-7a8e488e8606?w=400&q=75&fm=webp', title: 'Lake Louise Hotels', subtitle: 'Stay by the lake' },
      { href: '/hotel-directory?type=Resort', image: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=400&q=75&fm=webp', title: 'Luxury Resorts', subtitle: 'Mountain retreats' },
    ],
  },
};

const directLinks = [
  { href: '/trip-builder', label: 'Trip Ideas' },
  { href: '/blog', label: 'Guides' },
];
---

<div class="utility-bar" id="utility-bar">
  <div class="container utility-inner">
    <div class="utility-links">
      <a href="/events" class="utility-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        What's Happening
      </a>
      <a href="/weather-webcams" class="utility-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/><circle cx="12" cy="12" r="4"/></svg>
        Weather & Webcams
      </a>
      <a href="https://parks.canada.ca/pn-np/ab/banff/visit/pass" target="_blank" rel="noopener" class="utility-link utility-link--pass">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5h2a2 2 0 012 2v12a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
        Buy Your Park Pass
      </a>
    </div>
  </div>
</div>

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">&#9968;</span>
      <span class="logo-text">BanffBound</span>
    </a>

    <nav class="main-nav" id="main-nav">
      {Object.entries(megaMenus).map(([label, menu]) => (
        <div class="nav-item has-mega" data-menu={label}>
          <button class="nav-link mega-trigger" aria-expanded="false" aria-haspopup="true">
            {label}
            <svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
          </button>
          <div class="mega-panel" role="menu">
            <div class="container mega-inner">
              <div class="mega-links">
                <h4 class="mega-heading">{label}</h4>
                <ul>
                  {menu.links.map(link => (
                    <li>
                      <a href={link.href} class:list={['mega-link', { 'mega-link--cta': link.cta }]} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>
                        {link.label}
                        {link.external && <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 1h7v7M11 1L5 7"/></svg>}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="mega-featured">
                {menu.featured.map(item => (
                  <a href={item.href} class="mega-card">
                    <img src={item.image} alt={item.title} loading="lazy" />
                    <div class="mega-card-overlay">
                      <span class="mega-card-title">{item.title}</span>
                      <span class="mega-card-sub">{item.subtitle}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
      {directLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu">
    {Object.entries(megaMenus).map(([label, menu]) => (
      <div class="mobile-section">
        <button class="mobile-section-toggle" aria-expanded="false">
          {label}
          <svg class="chevron" width="12" height="12" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4l3 3 3-3"/></svg>
        </button>
        <div class="mobile-section-links">
          {menu.links.map(link => (
            <a href={link.href} class="mobile-link" {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    ))}
    {directLinks.map(link => (
      <a href={link.href} class="mobile-direct-link">{link.label}</a>
    ))}
  </div>
</header>

<style>
  /* ── Utility Bar ─────────────────────────────────── */
  .utility-bar {
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 0.8rem;
    transition: transform 0.3s ease;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1001;
  }
  .utility-bar.hidden { transform: translateY(-100%); }
  .utility-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 36px;
  }
  .utility-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .utility-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.85);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    transition: all 0.2s ease;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .utility-link:hover { color: #fff; background: rgba(255,255,255,0.1); }
  .utility-link--pass { color: var(--color-accent); font-weight: 600; }
  .utility-link--pass:hover { color: var(--color-accent-light); background: rgba(255,255,255,0.1); }

  /* ── Site Header ─────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 36px;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: all 0.3s ease;
  }
  .site-header.scrolled { top: 0; box-shadow: 0 2px 20px rgba(0,0,0,0.08); }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .logo-icon { font-size: 1.6rem; }

  /* ── Desktop Nav ─────────────────────────────────── */
  .main-nav {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .nav-item { position: relative; }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.8rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text);
    border-radius: 8px;
    transition: all 0.2s ease;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    white-space: nowrap;
  }
  .nav-link:hover { background: var(--color-bg-alt); color: var(--color-primary); }
  .nav-link.active { background: var(--color-primary); color: var(--color-white); }
  .chevron { transition: transform 0.2s ease; flex-shrink: 0; }
  .nav-item.open .chevron { transform: rotate(180deg); }
  .nav-item.open .mega-trigger { background: var(--color-bg-alt); color: var(--color-primary); }

  /* ── Mega Panel ──────────────────────────────────── */
  .mega-panel {
    position: fixed;
    top: 100px;
    left: 0;
    right: 0;
    background: var(--color-white);
    border-top: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.25s ease;
    z-index: 999;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
  }
  .site-header.scrolled .mega-panel { top: 64px; }
  .nav-item.open .mega-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .mega-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    padding: 2rem 1.5rem;
  }
  .mega-heading {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .mega-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .mega-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.6rem;
    font-size: 0.88rem;
    font-weight: 450;
    color: var(--color-text);
    border-radius: 6px;
    transition: all 0.15s ease;
  }
  .mega-link:hover {
    background: var(--color-bg-alt);
    color: var(--color-primary);
    padding-left: 0.9rem;
  }
  .mega-link svg { opacity: 0.5; flex-shrink: 0; }
  .mega-link--cta {
    background: var(--color-accent);
    color: var(--color-white) !important;
    font-weight: 600;
    margin-top: 0.5rem;
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
  }
  .mega-link--cta:hover {
    background: var(--color-accent-dark, #c4882a);
    color: var(--color-white) !important;
    padding-left: 0.8rem;
  }

  /* ── Featured Cards ──────────────────────────────── */
  .mega-featured {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    align-self: start;
  }
  .mega-card {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 4/5;
    display: block;
    transition: transform 0.2s ease;
  }
  .mega-card:hover { transform: translateY(-3px); }
  .mega-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .mega-card:hover img { transform: scale(1.05); }
  .mega-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;
  }
  .mega-card-title {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
  }
  .mega-card-sub {
    color: rgba(255,255,255,0.75);
    font-size: 0.78rem;
    margin-top: 0.2rem;
  }

  /* ── Backdrop ────────────────────────────────────── */
  .mega-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: all 0.25s ease;
  }
  .mega-backdrop.visible { opacity: 1; visibility: visible; }

  /* ── Mobile Toggle ───────────────────────────────── */
  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1002;
  }
  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-dark);
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .menu-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* ── Mobile Menu ─────────────────────────────────── */
  .mobile-menu {
    display: none;
    position: absolute;
    top: 64px;
    left: 0;
    right: 0;
    background: var(--color-white);
    border-top: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 0.5rem 0;
  }
  .mobile-menu.open { display: block; }
  .mobile-section { border-bottom: 1px solid rgba(0,0,0,0.04); }
  .mobile-section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.9rem 1.5rem;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .mobile-section-toggle:hover { background: var(--color-bg-alt); }
  .mobile-section-toggle .chevron { transition: transform 0.2s ease; }
  .mobile-section.open .mobile-section-toggle .chevron { transform: rotate(180deg); }
  .mobile-section.open .mobile-section-toggle { color: var(--color-primary); }
  .mobile-section-links {
    display: none;
    flex-direction: column;
    padding: 0 1rem 0.5rem 1rem;
  }
  .mobile-section.open .mobile-section-links { display: flex; }
  .mobile-link {
    padding: 0.55rem 1rem;
    font-size: 0.88rem;
    color: var(--color-text-light);
    border-radius: 6px;
    transition: all 0.15s ease;
  }
  .mobile-link:hover { background: var(--color-bg-alt); color: var(--color-primary); }
  .mobile-direct-link {
    display: block;
    padding: 0.9rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    transition: background 0.15s ease;
  }
  .mobile-direct-link:hover { background: var(--color-bg-alt); color: var(--color-primary); }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1100px) {
    .mega-featured { grid-template-columns: repeat(2, 1fr); }
    .mega-featured .mega-card:last-child { display: none; }
    .nav-link { padding: 0.45rem 0.6rem; font-size: 0.84rem; }
  }

  @media (max-width: 900px) {
    .utility-links { gap: 0; }
    .utility-link { padding: 0.3rem 0.5rem; font-size: 0.72rem; }
  }

  @media (max-width: 768px) {
    .main-nav { display: none; }
    .menu-toggle { display: flex; }
    .utility-link svg { display: none; }
    .utility-link { font-size: 0.7rem; padding: 0.3rem 0.4rem; }
    .mega-panel { display: none !important; }
  }

  @media (max-width: 480px) {
    .utility-link--pass span { display: none; }
    .utility-link { font-size: 0.65rem; padding: 0.25rem 0.3rem; gap: 0.2rem; }
  }
</style>

<div class="mega-backdrop" id="mega-backdrop"></div>

<script>
  const header = document.getElementById('site-header');
  const utilityBar = document.getElementById('utility-bar');
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mega-backdrop');
  const megaItems = document.querySelectorAll('.nav-item.has-mega');
  let lastScroll = 0;
  let activeMenu = null;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 50) {
      utilityBar?.classList.add('hidden');
      header?.classList.add('scrolled');
    } else {
      utilityBar?.classList.remove('hidden');
      header?.classList.remove('scrolled');
    }
    lastScroll = currentScroll;
  });

  function openMega(item) {
    if (activeMenu && activeMenu !== item) {
      activeMenu.classList.remove('open');
      const prevTrigger = activeMenu.querySelector('.mega-trigger');
      if (prevTrigger) prevTrigger.setAttribute('aria-expanded', 'false');
    }
    item.classList.add('open');
    const trigger = item.querySelector('.mega-trigger');
    if (trigger) trigger.setAttribute('aria-expanded', 'true');
    backdrop?.classList.add('visible');
    activeMenu = item;
  }

  function closeAllMega() {
    megaItems.forEach(item => {
      item.classList.remove('open');
      const trigger = item.querySelector('.mega-trigger');
      if (trigger) trigger.setAttribute('aria-expanded', 'false');
    });
    backdrop?.classList.remove('visible');
    activeMenu = null;
  }

  megaItems.forEach(item => {
    const trigger = item.querySelector('.mega-trigger');

    trigger?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (item.classList.contains('open')) {
        closeAllMega();
      } else {
        openMega(item);
      }
    });

    item.addEventListener('mouseenter', () => {
      openMega(item);
    });

    item.addEventListener('mouseleave', (e) => {
      const related = e.relatedTarget;
      if (related && (related.closest('.nav-item.has-mega') || related.closest('.mega-backdrop'))) return;
      closeAllMega();
    });
  });

  backdrop?.addEventListener('click', closeAllMega);
  backdrop?.addEventListener('mouseenter', closeAllMega);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAllMega();
      closeMobile();
    }
  });

  // Mobile
  function closeMobile() {
    mobileMenu?.classList.remove('open');
    toggle?.classList.remove('open');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      closeMobile();
    } else {
      mobileMenu?.classList.add('open');
      toggle?.classList.add('open');
    }
  });

  document.querySelectorAll('.mobile-section-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const section = btn.closest('.mobile-section');
      const wasOpen = section?.classList.contains('open');
      document.querySelectorAll('.mobile-section').forEach(s => s.classList.remove('open'));
      if (!wasOpen) section?.classList.add('open');
    });
  });

  document.querySelectorAll('.mobile-link, .mobile-direct-link').forEach(link => {
    link.addEventListener('click', closeMobile);
  });
</script>
