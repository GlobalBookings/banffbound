---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  lastUpdated?: string;
  category: string;
  image: string;
  readTime: string;
  slug?: string;
}

const { title, description, date, lastUpdated, category, image, readTime, slug } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
const isoDate = new Date(date).toISOString();
const isoModified = lastUpdated ? new Date(lastUpdated).toISOString() : isoDate;
const formattedModified = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : formattedDate;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image,
  datePublished: isoDate,
  dateModified: isoModified,
  author: {
    '@type': 'Person',
    name: 'Jack Chittenden',
    url: 'https://banffbound.com/about',
    sameAs: ['https://jack.me.uk', 'https://linkedin.com/in/jackchittenden'],
  },
  publisher: {
    '@type': 'Organization',
    name: 'BanffBound',
    url: 'https://banffbound.com',
  },
};
---

<BaseLayout title={title} description={description} image={image} lastUpdated={isoModified}>
  <div class="container">
    <Breadcrumbs items={[
      { label: 'Guides', href: '/blog' },
      { label: category, href: `/blog?category=${encodeURIComponent(category)}` },
      { label: title },
    ]} />
  </div>
  <article class="blog-article">
    <div class="article-hero">
      <img src={image} alt={title} class="article-hero-img" loading="eager" fetchpriority="high" />
      <div class="article-hero-overlay"></div>
      <div class="article-hero-content">
        <span class="badge">{category}</span>
        <h1>{title}</h1>
        <div class="article-meta">
          <a href="/about" class="author-link">Jack Chittenden</a>
          <span>&middot;</span>
          <time datetime={isoDate}>{formattedDate}</time>
          <span>&middot;</span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>
    <div class="expedia-leaderboard container">
      <div class="eg-affiliate-banners" data-program="ca-expedia" data-network="pz" data-layout="leaderboard" data-image="mountains" data-message="bye-bye-bucket-list-hello-adventure" data-camref="1101l3MtWX" data-pubref="" data-link="home"></div>
    </div>
    <div class="article-body container" data-category={category}>
      <slot />
      <div class="blog-email-capture">
        <p class="blog-email-heading">Enjoyed this guide? Get weekly Banff tips.</p>
        <form action="https://banffbound.us16.list-manage.com/subscribe/post?u=38050436b38afb17f1b30580a&amp;id=c419fe73a6&amp;f_id=002699e0f0" method="post" class="blog-email-form" target="_blank" novalidate>
          <div class="blog-email-group">
            <input type="email" name="EMAIL" placeholder="Your email address" required aria-label="Email address" />
            <button type="submit" class="btn btn-accent">Subscribe</button>
          </div>
          <div aria-hidden="true" style="position: absolute; left: -5000px;"><input type="text" name="b_38050436b38afb17f1b30580a_c419fe73a6" tabindex="-1" value="" /></div>
        </form>
      </div>
      <div class="gyg-widget-container">
        <h2>Recommended Tours & Activities</h2>
        <div data-gyg-widget="auto" data-gyg-partner-id="QW960HO" data-gyg-cmp="banffboundblog"></div>
      </div>
      <div class="article-footer">
        <div class="article-updated">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Last updated: <time datetime={isoModified}>{formattedModified}</time>
        </div>
        <div class="author-bio-card">
          <div class="author-bio-avatar">JC</div>
          <div class="author-bio-info">
            <strong>Written by Jack Chittenden</strong>
            <p>Banff-based adventure writer. Ironman finisher, ultra-runner, and full-time Rocky Mountains explorer. 70+ trails hiked, 95+ hotels reviewed.</p>
            <div class="author-bio-links">
              <a href="/about">About Jack</a>
              <a href="https://linkedin.com/in/jackchittenden" target="_blank" rel="noopener">LinkedIn</a>
            </div>
          </div>
        </div>
        <a href="/blog" class="btn btn-outline">&larr; Back to All Guides</a>
        <p class="trip-report-cta">Been to Banff? <a href="/trip-reports">Share your trip report</a> and help fellow travellers plan their adventure.</p>
      </div>
    </div>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline class="eg-affiliate-banners-script" src="https://creator.expediagroup.com/products/banners/assets/eg-affiliate-banners.js"></script>
  <script is:inline src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="QW960HO"></script>
  <script is:inline>
  (function() {
    var body = document.querySelector('.article-body');
    if (!body) return;
    var cat = (body.dataset.category || '').toLowerCase();

    // Category-specific CTA config
    var ctaConfig = {
      'hiking': { heading: 'Plan Your Hike', desc: 'Find guided hiking tours and trail-side accommodation in Banff.', btn1: { text: 'Explore 81 Trails', href: '/trails' }, gyg: 'Browse Hiking Tours', gygQ: '&q=hiking' },
      'food & drink': { heading: 'Hungry in Banff?', desc: 'Discover guided food tours and hotels near the best restaurants.', btn1: { text: 'Full Restaurant Guide', href: '/eat-and-drink' }, gyg: 'Food & Drink Tours', gygQ: '&q=food' },
      'accommodation': { heading: 'Find Your Stay', desc: 'Compare 95+ Banff hotels by area, budget and amenities.', btn1: { text: 'Compare 95+ Hotels', href: '/hotel-directory' }, gyg: 'Browse Tours', gygQ: '' },
      'seasonal': { heading: 'Plan Your Season', desc: 'Book seasonal activities and find the best deals on accommodation.', btn1: { text: 'Trip Builder', href: '/trip-builder' }, gyg: 'Seasonal Activities', gygQ: '' },
      'itineraries': { heading: 'Build Your Trip', desc: 'Use our interactive planner to customise your Banff itinerary.', btn1: { text: 'Trip Builder', href: '/trip-builder' }, gyg: 'Browse Tours', gygQ: '' },
      'planning': { heading: 'Plan Your Banff Trip', desc: 'Compare hotels, book tours, and get your park pass sorted.', btn1: { text: 'Compare 95+ Hotels', href: '/hotel-directory' }, gyg: 'Browse Tours', gygQ: '' },
      'tips': { heading: 'Make the Most of Banff', desc: 'Book activities and find accommodation for your trip.', btn1: { text: 'Trip Builder', href: '/trip-builder' }, gyg: 'Browse Activities', gygQ: '' },
    };
    var cfg = ctaConfig[cat] || { heading: 'Plan Your Banff Trip', desc: 'Find hotels, tours, and activities for your Canadian Rockies adventure.', btn1: { text: 'Compare 95+ Hotels', href: '/hotel-directory' }, gyg: 'Browse Tours', gygQ: '' };

    var h2s = body.querySelectorAll('h2');
    if (h2s.length < 2) return;
    var contentH2s = [];
    for (var i = 0; i < h2s.length; i++) {
      if (!h2s[i].closest('.gyg-widget-container')) contentH2s.push(h2s[i]);
    }
    if (contentH2s.length < 2) return;

    var cta = document.createElement('div');
    cta.className = 'mid-article-cta';
    cta.innerHTML =
      '<div class="mid-cta-inner">' +
        '<strong>' + cfg.heading + '</strong>' +
        '<p>' + cfg.desc + '</p>' +
        '<div class="mid-cta-buttons">' +
          '<a href="' + cfg.btn1.href + '" class="mid-cta-btn">' + cfg.btn1.text + '</a>' +
          '<a href="https://www.getyourguide.com/banff-l284/?partner_id=QW960HO' + cfg.gygQ + '" target="_blank" rel="noopener sponsored" class="mid-cta-btn mid-cta-gyg">' + cfg.gyg + '</a>' +
          '<a href="https://www.expedia.ca/Hotel-Search?destination=Banff%2C+Alberta&camref=1101l3MtWX" target="_blank" rel="noopener sponsored" class="mid-cta-btn mid-cta-exp">Check Hotel Deals</a>' +
        '</div>' +
      '</div>';
    contentH2s[1].parentNode.insertBefore(cta, contentH2s[1]);

    // Sticky CTA bar — appears after scrolling past hero
    var sticky = document.createElement('div');
    sticky.className = 'sticky-cta-bar';
    sticky.innerHTML =
      '<div class="sticky-cta-inner">' +
        '<span>' + cfg.heading + '</span>' +
        '<div class="sticky-cta-links">' +
          '<a href="' + cfg.btn1.href + '" class="sticky-cta-btn">' + cfg.btn1.text + '</a>' +
          '<a href="https://www.getyourguide.com/banff-l284/?partner_id=QW960HO' + cfg.gygQ + '" target="_blank" rel="noopener sponsored" class="sticky-cta-btn sticky-gyg">' + cfg.gyg + '</a>' +
        '</div>' +
      '</div>';
    document.body.appendChild(sticky);

    var hero = document.querySelector('.article-hero');
    var stickyVisible = false;
    window.addEventListener('scroll', function() {
      var threshold = hero ? hero.offsetHeight + hero.offsetTop : 400;
      var shouldShow = window.scrollY > threshold;
      if (shouldShow !== stickyVisible) {
        stickyVisible = shouldShow;
        sticky.classList.toggle('sticky-visible', shouldShow);
      }
    });
  })();
  </script>
</BaseLayout>

<style>
  .gyg-widget-container {
    margin: 2.5rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .gyg-widget-container h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .expedia-leaderboard {
    text-align: center;
    padding: 1.5rem 0 0;
    max-width: 728px;
    margin: 0 auto;
  }

  .article-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .article-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 60%);
  }

  .article-hero-content {
    position: relative;
    z-index: 2;
    color: var(--color-white);
    padding: 3rem;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .article-hero-content h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.5rem 0;
    max-width: 800px;
  }

  .article-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .article-meta :global(.author-link) {
    color: var(--color-white);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 500;
  }

  .article-body {
    max-width: 800px;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .article-body :global(h2) {
    margin: 2.5rem 0 1rem;
    font-size: 1.8rem;
  }

  .article-body :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.3rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
    line-height: 1.8;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-body :global(strong) {
    color: var(--color-dark);
  }

  .article-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    background: var(--color-bg-alt);
    padding: 1.25rem 1.5rem;
    border-radius: 0 var(--radius) var(--radius) 0;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .article-body :global(.tip-box) {
    background: var(--color-bg-alt);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .article-body :global(.editor-note) {
    background: var(--color-bg-alt);
    border-left: 4px solid #2d6a4f;
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    font-size: 0.97em;
    line-height: 1.6;
  }

  .blog-email-capture {
    margin: 2.5rem 0;
    padding: 2rem;
    border: 2px solid var(--color-bg-alt);
    border-radius: var(--radius);
    background: var(--color-bg-alt);
    text-align: center;
  }

  .blog-email-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .blog-email-form {
    max-width: 420px;
    margin: 0 auto;
  }

  .blog-email-group {
    display: flex;
    gap: 0.5rem;
  }

  .blog-email-group input[type="email"] {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 2px solid rgba(0,0,0,0.08);
    border-radius: var(--radius);
    background: var(--color-white);
    font-size: 0.95rem;
    font-family: var(--font-body);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .blog-email-group input[type="email"]:focus {
    border-color: var(--color-accent);
  }

  .blog-email-group .btn {
    white-space: nowrap;
    flex-shrink: 0;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .article-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .author-bio-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: var(--color-bg-alt);
    border-radius: var(--radius);
    width: 100%;
  }

  .author-bio-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    flex-shrink: 0;
    border: 3px solid var(--color-accent);
  }

  .author-bio-info strong {
    font-size: 1rem;
    color: var(--color-dark);
    display: block;
    margin-bottom: 0.35rem;
  }

  .author-bio-info p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .author-bio-links {
    display: flex;
    gap: 1rem;
  }

  .author-bio-links a {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .author-bio-links a:hover {
    color: var(--color-accent);
  }

  .trip-report-cta {
    font-size: 0.85rem;
    color: var(--color-text-light);
    margin-top: 0.5rem;
  }

  .trip-report-cta a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .trip-report-cta a:hover {
    color: var(--color-accent);
  }

  .article-body :global(.mid-article-cta) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #2d6b4a 100%);
    border-radius: var(--radius);
    color: var(--color-white);
  }

  .article-body :global(.mid-cta-inner strong) {
    font-size: 1.1rem;
    color: var(--color-white);
    display: block;
    margin-bottom: 0.25rem;
  }

  .article-body :global(.mid-cta-inner p) {
    color: rgba(255,255,255,0.85);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .article-body :global(.mid-cta-buttons) {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .article-body :global(.mid-cta-btn) {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    background: rgba(255,255,255,0.15);
    color: var(--color-white);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .article-body :global(.mid-cta-btn:hover) {
    background: rgba(255,255,255,0.25);
    color: var(--color-white);
  }

  .article-body :global(.mid-cta-gyg) {
    background: var(--color-accent);
    color: var(--color-dark);
    border-color: var(--color-accent);
  }

  .article-body :global(.mid-cta-gyg:hover) {
    background: #c49a3a;
    color: var(--color-dark);
  }

  .article-body :global(.mid-cta-exp) {
    background: var(--color-white);
    color: var(--color-primary);
    border-color: var(--color-white);
  }

  .article-body :global(.mid-cta-exp:hover) {
    background: #f0f0f0;
    color: var(--color-primary);
  }

  :global(.sticky-cta-bar) {
    position: fixed;
    bottom: -60px;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-primary);
    color: white;
    padding: 0.6rem 1rem;
    transition: bottom 0.3s ease;
    box-shadow: 0 -2px 8px rgba(0,0,0,0.15);
  }

  :global(.sticky-cta-bar.sticky-visible) { bottom: 0; }

  :global(.sticky-cta-inner) {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  :global(.sticky-cta-inner span) { font-weight: 600; font-size: 0.9rem; }

  :global(.sticky-cta-links) { display: flex; gap: 0.5rem; }

  :global(.sticky-cta-btn) {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    background: var(--color-accent);
    color: var(--color-white);
    text-decoration: none;
    white-space: nowrap;
  }

  :global(.sticky-cta-btn:hover) { opacity: 0.9; }
  :global(.sticky-gyg) { background: rgba(255,255,255,0.2); }
  :global(.sticky-gyg:hover) { background: rgba(255,255,255,0.3); }

  @media (max-width: 768px) {
    .article-hero { min-height: 300px; }
    .article-hero-content { padding: 1.5rem; }
    .article-body :global(.mid-cta-buttons) { flex-direction: column; }
    :global(.sticky-cta-inner span) { display: none; }
    :global(.sticky-cta-btn) { font-size: 0.75rem; padding: 0.4rem 0.7rem; }
    .blog-email-group { flex-direction: column; }
    .blog-email-group .btn { width: 100%; }
    .author-bio-card { flex-direction: column; align-items: center; text-align: center; }
    .author-bio-links { justify-content: center; }
  }
</style>
