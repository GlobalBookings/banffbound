---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  image: string;
  readTime: string;
  slug?: string;
}

const { title, description, date, category, image, readTime, slug } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
const isoDate = new Date(date).toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image,
  datePublished: isoDate,
  dateModified: isoDate,
  author: { '@type': 'Organization', name: 'BanffBound' },
  publisher: {
    '@type': 'Organization',
    name: 'BanffBound',
    url: 'https://banffbound.com',
  },
};
---

<BaseLayout title={title} description={description} image={image} lastUpdated={isoDate}>
  <div class="container">
    <Breadcrumbs items={[
      { label: 'Guides', href: '/blog' },
      { label: category, href: `/blog?category=${encodeURIComponent(category)}` },
      { label: title },
    ]} />
  </div>
  <article class="blog-article">
    <div class="article-hero">
      <img src={image} alt={title} class="article-hero-img" loading="eager" fetchpriority="high" />
      <div class="article-hero-overlay"></div>
      <div class="article-hero-content">
        <span class="badge">{category}</span>
        <h1>{title}</h1>
        <div class="article-meta">
          <time datetime={isoDate}>{formattedDate}</time>
          <span>&middot;</span>
          <span>{readTime}</span>
        </div>
      </div>
    </div>
    <div class="expedia-leaderboard container">
      <div class="eg-affiliate-banners" data-program="ca-expedia" data-network="pz" data-layout="leaderboard" data-image="mountains" data-message="bye-bye-bucket-list-hello-adventure" data-camref="1101l3MtWX" data-pubref="" data-link="home"></div>
    </div>
    <div class="article-body container">
      <slot />
      <div class="gyg-widget-container">
        <h2>Recommended Tours & Activities</h2>
        <div data-gyg-widget="auto" data-gyg-partner-id="QW960HO" data-gyg-cmp="banffboundblog"></div>
      </div>
      <div class="article-footer">
        <div class="article-updated">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Last updated: <time datetime={isoDate}>{formattedDate}</time>
        </div>
        <a href="/blog" class="btn btn-outline">&larr; Back to All Guides</a>
      </div>
    </div>
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script is:inline class="eg-affiliate-banners-script" src="https://creator.expediagroup.com/products/banners/assets/eg-affiliate-banners.js"></script>
  <script is:inline src="https://widget.getyourguide.com/dist/pa.umd.production.min.js" data-gyg-partner-id="QW960HO"></script>
  <script is:inline>
  (function() {
    var body = document.querySelector('.article-body');
    if (!body) return;
    var h2s = body.querySelectorAll('h2');
    if (h2s.length < 2) return;
    // Skip the "Recommended Tours" h2 at the bottom (inside gyg-widget-container)
    var contentH2s = [];
    for (var i = 0; i < h2s.length; i++) {
      if (!h2s[i].closest('.gyg-widget-container')) contentH2s.push(h2s[i]);
    }
    if (contentH2s.length < 2) return;

    var cta = document.createElement('div');
    cta.className = 'mid-article-cta';
    cta.innerHTML =
      '<div class="mid-cta-inner">' +
        '<strong>Plan Your Banff Trip</strong>' +
        '<p>Find hotels, tours, and activities for your Canadian Rockies adventure.</p>' +
        '<div class="mid-cta-buttons">' +
          '<a href="/hotel-directory" class="mid-cta-btn">Compare 95+ Hotels</a>' +
          '<a href="https://www.getyourguide.com/banff-l284/?partner_id=QW960HO" target="_blank" rel="noopener sponsored" class="mid-cta-btn mid-cta-gyg">Browse Tours</a>' +
          '<a href="https://www.expedia.ca/Hotel-Search?destination=Banff%2C+Alberta&camref=1101l3MtWX" target="_blank" rel="noopener sponsored" class="mid-cta-btn mid-cta-exp">Check Hotel Deals</a>' +
        '</div>' +
      '</div>';
    contentH2s[1].parentNode.insertBefore(cta, contentH2s[1]);
  })();
  </script>
</BaseLayout>

<style>
  .gyg-widget-container {
    margin: 2.5rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .gyg-widget-container h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .expedia-leaderboard {
    text-align: center;
    padding: 1.5rem 0 0;
    max-width: 728px;
    margin: 0 auto;
  }

  .article-hero {
    position: relative;
    height: 50vh;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .article-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 60%);
  }

  .article-hero-content {
    position: relative;
    z-index: 2;
    color: var(--color-white);
    padding: 3rem;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .article-hero-content h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.5rem 0;
    max-width: 800px;
  }

  .article-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .article-body {
    max-width: 800px;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .article-body :global(h2) {
    margin: 2.5rem 0 1rem;
    font-size: 1.8rem;
  }

  .article-body :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.3rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-body :global(ul), .article-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
    line-height: 1.8;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .article-body :global(strong) {
    color: var(--color-dark);
  }

  .article-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    background: var(--color-bg-alt);
    padding: 1.25rem 1.5rem;
    border-radius: 0 var(--radius) var(--radius) 0;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .article-body :global(.tip-box) {
    background: var(--color-bg-alt);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .article-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--color-text-light);
  }

  .article-body :global(.mid-article-cta) {
    margin: 2rem 0;
    padding: 1.5rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #2d6b4a 100%);
    border-radius: var(--radius);
    color: var(--color-white);
  }

  .article-body :global(.mid-cta-inner strong) {
    font-size: 1.1rem;
    color: var(--color-white);
    display: block;
    margin-bottom: 0.25rem;
  }

  .article-body :global(.mid-cta-inner p) {
    color: rgba(255,255,255,0.85);
    margin-bottom: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .article-body :global(.mid-cta-buttons) {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .article-body :global(.mid-cta-btn) {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    background: rgba(255,255,255,0.15);
    color: var(--color-white);
    border: 1px solid rgba(255,255,255,0.3);
  }

  .article-body :global(.mid-cta-btn:hover) {
    background: rgba(255,255,255,0.25);
    color: var(--color-white);
  }

  .article-body :global(.mid-cta-gyg) {
    background: var(--color-accent);
    color: var(--color-dark);
    border-color: var(--color-accent);
  }

  .article-body :global(.mid-cta-gyg:hover) {
    background: #c49a3a;
    color: var(--color-dark);
  }

  .article-body :global(.mid-cta-exp) {
    background: var(--color-white);
    color: var(--color-primary);
    border-color: var(--color-white);
  }

  .article-body :global(.mid-cta-exp:hover) {
    background: #f0f0f0;
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .article-hero { min-height: 300px; }
    .article-hero-content { padding: 1.5rem; }
    .article-body :global(.mid-cta-buttons) { flex-direction: column; }
  }
</style>
