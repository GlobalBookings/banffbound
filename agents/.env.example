# ── Google OAuth 2.0 (from Cloud Console > Credentials) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Google Ads ──
GOOGLE_ADS_CUSTOMER_ID=          # 10-digit ID, no dashes (e.g. 1234567890)
GOOGLE_ADS_DEVELOPER_TOKEN=      # From ads.google.com > Tools > API Centre
GOOGLE_ADS_LOGIN_CUSTOMER_ID=    # MCC ID if using a manager account, otherwise same as CUSTOMER_ID

# ── Google Analytics 4 ──
GA4_PROPERTY_ID=494425433

# ── Google Search Console ──
SEARCH_CONSOLE_SITE_URL=https://banffbound-33cfa.ondigitalocean.app

# ── Slack ──
SLACK_WEBHOOK_URL=

# ── Content Publisher ──
ANTHROPIC_API_KEY=               # From console.anthropic.com > API Keys
OPENAI_API_KEY=                  # From platform.openai.com > API Keys (for DALL-E 3 images)
GITHUB_TOKEN=                    # Personal access token with repo scope
GITHUB_REPO=GlobalBookings/banffbound

# ── DataForSEO ──
DATAFORSEO_LOGIN=                # From app.dataforseo.com/api-access
DATAFORSEO_PASSWORD=             # API password (not your account password)
SITE_DOMAIN=banffbound.com       # Domain to monitor (no https://)

